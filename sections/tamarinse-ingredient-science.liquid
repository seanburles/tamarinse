{% comment %}
  Ingredient Science (MASTER_PROMPT #8) — an ingredient index: sticky intro
  rail on the left, numbered accordion of the six ingredients on the right
  (exclusive open via details name=""). Replaces the six-card grid, which
  stretched the page with repeated research-org lists.

  Primary data path: the Ingredient metaobject via metaobject_list dynamic
  source. Fallback path: editable blocks with defaults from
  data/ingredients.json until the metaobject entries exist in admin.
{% endcomment %}

{%- liquid
  assign use_metaobjects = false
  if section.settings.ingredients != blank and section.settings.ingredients.count > 0
    assign use_metaobjects = true
  endif
-%}

<section class="tamarinse-science t-on-light" id="TamarinseScience-{{ section.id }}">
  <div class="tamarinse-science__inner">
    <header class="tamarinse-science__rail">
      <p class="t-eyebrow tamarinse-science__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tamarinse-science__title">{{ section.settings.title }}</h2>
      <p class="tamarinse-science__intro">{{ section.settings.intro }}</p>

      <div class="tamarinse-science__close">
        <p class="tamarinse-science__close-title">{{ section.settings.close_title }}</p>
        <p class="tamarinse-science__close-text">{{ section.settings.close_text }}</p>
      </div>
    </header>

    <div class="tamarinse-science__list">
      {%- if use_metaobjects -%}
        {%- for ingredient in section.settings.ingredients -%}
          {%- liquid
            assign orgs_joined = ''
            for org in ingredient.research_orgs.value
              assign orgs_joined = orgs_joined | append: org | append: ';'
            endfor
          -%}
          {%- render 'tamarinse-ingredient-card',
            name: ingredient.name,
            what_it_is: ingredient.what_it_is,
            why_we_chose_it: ingredient.why_we_chose_it,
            research_orgs: orgs_joined,
            orgs_label: section.settings.orgs_label,
            index: forloop.index,
            open: forloop.first
          -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }} style="display: contents;">
            {%- render 'tamarinse-ingredient-card',
              name: block.settings.name,
              what_it_is: block.settings.what_it_is,
              why_we_chose_it: block.settings.why_we_chose_it,
              research_orgs: block.settings.research_orgs,
              orgs_label: section.settings.orgs_label,
              index: forloop.index,
              open: forloop.first,
              image: block.settings.image
            -%}
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- if section.settings.close_kicker != blank -%}
        <p class="tamarinse-science__kicker">{{ section.settings.close_kicker }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .tamarinse-science {
    display: block;
    background: var(--t-tint);
    color: var(--t-text-hi);
    padding: var(--t-space-section) var(--t-space-md);
  }

  .tamarinse-science__inner {
    max-width: var(--t-content-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--t-space-xl);
  }

  .tamarinse-science__eyebrow {
    color: var(--t-text-low);
    margin: 0 0 var(--t-space-sm);
  }

  .tamarinse-science__title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    margin: 0 0 var(--t-space-sm);
    text-wrap: balance;
  }

  .tamarinse-science__intro {
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    margin: 0;
    max-width: var(--t-copy-max);
  }

  .tamarinse-science__close {
    margin-block-start: var(--t-space-lg);
    padding-block-start: var(--t-space-md);
    border-block-start: 1px solid var(--t-border);
    max-width: var(--t-copy-max);
  }

  .tamarinse-science__close-title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-body-lg);
    font-weight: var(--t-weight-subheading);
    margin: 0 0 var(--t-space-2xs);
  }

  .tamarinse-science__close-text {
    font-size: var(--t-type-small);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    margin: 0;
  }

  /* ---- Accordion ---- */

  .tamarinse-science__list {
    interpolate-size: allow-keywords;
  }

  .tamarinse-science__item {
    border-block-start: 1px solid var(--t-border);
  }

  .tamarinse-science__item:last-of-type {
    border-block-end: 1px solid var(--t-border);
  }

  .tamarinse-science__row {
    display: flex;
    align-items: baseline;
    gap: var(--t-space-md);
    min-height: var(--t-touch-target);
    padding: var(--t-space-md) 0;
    cursor: pointer;
    list-style: none;
  }

  .tamarinse-science__row::-webkit-details-marker {
    display: none;
  }

  .tamarinse-science__index {
    flex: none;
    font-size: var(--t-type-small);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: var(--t-text-low);
    transition: color var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-science__name {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h3);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-subheading);
    margin: 0;
    flex: 1;
  }

  .tamarinse-science__item[open] .tamarinse-science__index {
    color: var(--t-accent);
  }

  .tamarinse-science__marker {
    flex: none;
    position: relative;
    align-self: center;
    width: 16px;
    height: 16px;
  }

  .tamarinse-science__marker::before,
  .tamarinse-science__marker::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto;
    height: 1.5px;
    background: var(--t-text-mid);
    transition: transform var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-science__marker::after {
    transform: rotate(90deg);
  }

  .tamarinse-science__item[open] .tamarinse-science__marker::after {
    transform: rotate(0deg);
  }

  /* Animated expansion (progressive enhancement: older browsers snap open) */
  .tamarinse-science__item::details-content {
    block-size: 0;
    overflow: clip;
    transition:
      block-size var(--t-dur-med) var(--t-ease-out),
      content-visibility var(--t-dur-med) allow-discrete;
  }

  .tamarinse-science__item[open]::details-content {
    block-size: auto;
  }

  .tamarinse-science__panel {
    padding-block-end: var(--t-space-lg);
  }

  .tamarinse-science__detail {
    display: flex;
    flex-direction: column-reverse;
    gap: var(--t-space-md);
  }

  .tamarinse-science__copy {
    flex: 1;
  }

  .tamarinse-science__what,
  .tamarinse-science__why {
    font-size: var(--t-type-body);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    margin: 0 0 var(--t-space-xs);
    max-width: 56ch;
  }

  .tamarinse-science__orgs-label {
    color: var(--t-text-low);
    margin: var(--t-space-sm) 0 var(--t-space-2xs);
    font-size: 0.6875rem;
  }

  .tamarinse-science__orgs {
    margin: 0;
    font-size: var(--t-type-small);
    line-height: 1.9;
    color: var(--t-text-low);
    max-width: 56ch;
  }

  .tamarinse-science__orgs span::after {
    content: '·';
    margin-inline: 0.5em;
  }

  .tamarinse-science__orgs span:last-child::after {
    content: none;
  }

  .tamarinse-science__media {
    flex: none;
    width: 150px;
  }

  .tamarinse-science__photo {
    width: 100%;
    height: auto;
    mix-blend-mode: multiply; /* white product-photo backgrounds melt into the sand panel */
  }

  .tamarinse-science__kicker {
    margin: var(--t-space-md) 0 0;
    font-size: var(--t-type-small);
    line-height: var(--t-leading-body);
    color: var(--t-text-low);
  }

  @media (prefers-reduced-motion: reduce) {
    .tamarinse-science__item::details-content,
    .tamarinse-science__marker::before,
    .tamarinse-science__marker::after {
      transition: none;
    }
  }

  @media screen and (min-width: 990px) {
    .tamarinse-science__inner {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--t-space-2xl);
      align-items: start;
    }

    .tamarinse-science__rail {
      position: sticky;
      top: calc(var(--header-height, 64px) + var(--t-space-lg));
    }

    .tamarinse-science__detail {
      flex-direction: row;
      align-items: flex-start;
    }

    .tamarinse-science__media {
      width: 180px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ingredient Science",
  "tag": "section",
  "class": "tamarinse-science-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ingredient Science"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Built on Published Research"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Every ingredient in Tamarinse™ was selected for a specific purpose. Each ingredient is supported by published research from respected universities, medical organizations, and peer-reviewed scientific journals."
    },
    {
      "type": "text",
      "id": "orgs_label",
      "label": "Research orgs label",
      "default": "Research Organizations"
    },
    {
      "type": "metaobject_list",
      "id": "ingredients",
      "label": "Ingredients (metaobject)",
      "metaobject_type": "ingredient",
      "info": "When connected, these replace the ingredient blocks below so all sections share one editable list."
    },
    {
      "type": "header",
      "content": "Section close"
    },
    {
      "type": "text",
      "id": "close_title",
      "label": "Close title",
      "default": "Every Ingredient. Every Purpose."
    },
    {
      "type": "textarea",
