{% comment %}
  Interactive Capsule — signature scroll-driven sequence (MASTER_PROMPT #6).
  Capsule separates → delayed-release copy → six ingredients reveal one at a
  time → capsule closes.

  Ingredient data: connect the "Ingredients" metaobject list setting
  (Content > Metaobjects > Ingredient, see metaobjects/ingredient-definition.md).
  Until those entries exist, the section falls back to its editable ingredient
  blocks (defaults seeded from data/ingredients.json).
{% endcomment %}

{%- liquid
  assign use_metaobjects = false
  if section.settings.ingredients != blank and section.settings.ingredients.count > 0
    assign use_metaobjects = true
  endif

  # ---- Timeline geometry (single source of truth) ----
  # These fractions of the pinned range must match the ingredient window in
  # tamarinse-capsule-timeline.js; they are handed to the JS via data
  # attributes below so the scroll-snap steps and the reveal logic can never
  # drift apart.
  assign ingredient_count = section.blocks.size
  if use_metaobjects
    assign ingredient_count = section.settings.ingredients.count
  endif
  if ingredient_count < 1
    assign ingredient_count = 1
  endif

  assign ing_start = 0.16
  assign ing_end = 0.9

  # Phones scroll the same timeline over a longer track (see the section
  # setting). The ingredient window itself is identical at every breakpoint,
  # so the snap steps below stay valid either way.
  assign scroll_boost = section.settings.mobile_scroll_boost | default: 160
  assign mobile_scroll = section.settings.scroll_length | times: scroll_boost | divided_by: 100
  assign ing_span = ing_end | minus: ing_start | divided_by: ingredient_count
  # Lead-in puts the first snap point at the CENTRE of ingredient one
  assign ing_lead = ing_span | times: 0.5 | plus: ing_start
-%}

{%- comment -%} Ingredient icons — one per default block order {%- endcomment -%}
{%- capture icon_1 -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><ellipse cx="12" cy="12" rx="6" ry="9"/><path d="M9 4c1.5 4 1.5 12 0 16"/></svg>{%- endcapture -%}
{%- capture icon_2 -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="12" r="4"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="12" r="4"/></svg>{%- endcapture -%}
{%- capture icon_3 -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V10"/><path d="M5 4c0 6 7 8 7 8"/><path d="M19 4c0 6-7 8-7 8"/></svg>{%- endcapture -%}
{%- capture icon_4 -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M12 2l9 5v10l-9 5-9-5V7Z"/><path d="m12 12 9-5" stroke-linecap="round"/><path d="m12 12-9-5" stroke-linecap="round"/><path d="M12 12v10" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture icon_5 -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/></svg>{%- endcapture -%}
{%- capture icon_6 -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c0 0-8 7.5-8 13a8 8 0 0 0 16 0c0-5.5-8-13-8-13Z"/><path d="M12 22v-7"/><path d="M9 18c1.5-2 3-3 3-5"/><path d="M15 18c-1.5-2-3-3-3-5"/></svg>{%- endcapture -%}

<tamarinse-capsule-sequence
  class="tamarinse-capsule"
  id="TamarinseCapsule-{{ section.id }}"
  {%- comment -%}
    Two lengths, one per breakpoint. Phones get a longer track for the same
    six ingredients, so each reveal owns more absolute scroll — the stylesheet
    picks which one feeds --capsule-scroll-length. Inline styles beat
    stylesheet rules, so the breakpoint choice can't live on that property
    directly; it selects between these two instead.
  {%- endcomment -%}
  style="--capsule-scroll-desktop: {{ section.settings.scroll_length }}vh; --capsule-scroll-mobile: {{ mobile_scroll }}vh;"
  data-frame-count="61"
  data-frames-desktop="{{ 'tamarinse-capsule-frame-d-000.webp' | asset_url }}"
  data-frames-mobile="{{ 'tamarinse-capsule-frame-m-000.webp' | asset_url }}"
  data-snap="{% if section.settings.snap_to_ingredient %}true{% else %}false{% endif %}"
  data-ingredients-start="{{ ing_start }}"
  data-ingredients-end="{{ ing_end }}"
>
  <div class="tamarinse-capsule__sticky">
    {%- comment -%}
      Scroll-scrubbed image sequence (rendered from the capsule video) —
      the JS draws the frame matching scroll progress onto this canvas.
    {%- endcomment -%}
    <canvas class="tamarinse-capsule__canvas" aria-hidden="true"></canvas>

    <p class="t-eyebrow t-eyebrow--ruled-both tamarinse-capsule__eyebrow">{{ section.settings.eyebrow }}</p>

    <div class="tamarinse-capsule__stage" aria-hidden="true">
      <div class="tamarinse-capsule__reveal">
        {%- if use_metaobjects -%}
          {%- for ingredient in section.settings.ingredients -%}
            {%- assign current_icon = '' -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- assign current_icon = icon_1 -%}
              {%- when 2 -%}
                {%- assign current_icon = icon_2 -%}
              {%- when 3 -%}
                {%- assign current_icon = icon_3 -%}
              {%- when 4 -%}
                {%- assign current_icon = icon_4 -%}
              {%- when 5 -%}
                {%- assign current_icon = icon_5 -%}
              {%- when 6 -%}
                {%- assign current_icon = icon_6 -%}
            {%- endcase -%}
            <span class="tamarinse-capsule__ingredient" data-capsule-ingredient>
              <span class="tamarinse-capsule__icon" aria-hidden="true">{{ current_icon }}</span>
              <strong>{{ ingredient.name }}</strong>
              <em>{{ ingredient.what_it_is }}</em>
            </span>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- assign current_icon = '' -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- assign current_icon = icon_1 -%}
              {%- when 2 -%}
                {%- assign current_icon = icon_2 -%}
              {%- when 3 -%}
                {%- assign current_icon = icon_3 -%}
              {%- when 4 -%}
                {%- assign current_icon = icon_4 -%}
              {%- when 5 -%}
                {%- assign current_icon = icon_5 -%}
              {%- when 6 -%}
                {%- assign current_icon = icon_6 -%}
            {%- endcase -%}
            <span class="tamarinse-capsule__ingredient" data-capsule-ingredient {{ block.shopify_attributes }}>
              <span class="tamarinse-capsule__icon" aria-hidden="true">{{ current_icon }}</span>
              <strong>{{ block.settings.name }}</strong>
              <em>{{ block.settings.description }}</em>
            </span>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <div class="tamarinse-capsule__copy">
      <p class="tamarinse-capsule__layer-one">
        <strong>{{ section.settings.layer_one_title }}</strong>
        {{ section.settings.layer_one_text }}
      </p>
      {%- comment -%}
        Real buttons, not decoration: tapping one jumps to that ingredient.
        This is the non-gesture route through the content (WCAG 2.2 — people
        shouldn't need a specific scroll gesture to reach anything) and gives
        anyone who wants deterministic control a way to step through.
      {%- endcomment -%}
      <div class="tamarinse-capsule__dots" role="group" aria-label="{{ 'Choose an ingredient' }}">
        {%- if use_metaobjects -%}
          {%- for ingredient in section.settings.ingredients -%}
            <button
              type="button"
              class="tamarinse-capsule__dot"
              data-capsule-dot
              data-index="{{ forloop.index0 }}"
            >
              <span class="visually-hidden">{{ ingredient.name }}</span>
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="tamarinse-capsule__dot"
              data-capsule-dot
              data-index="{{ forloop.index0 }}"
            >
              <span class="visually-hidden">{{ block.settings.name }}</span>
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Accessible/SEO version of the reveal content {%- endcomment -%}
    <ul class="visually-hidden">
      {%- if use_metaobjects -%}
        {%- for ingredient in section.settings.ingredients -%}
          <li>{{ ingredient.name }} — {{ ingredient.what_it_is }}</li>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <li>{{ block.settings.name }} — {{ block.settings.description }}</li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>

  {%- comment -%}
    Scroll-snap steps (client 2026-07-18). These invisible blocks carry the
    section's scroll length AND act as native snap targets: one per
    ingredient, positioned so its top edge lands on that ingredient's centre
    of the timeline. `scroll-snap-stop: always` is the important bit — it
    stops a momentum fling at EACH ingredient instead of letting one swipe
    sail past several, which is what made the reveals unreadable on iOS.
    Native snap decides the landing point during the fling (in the
    compositor), so it never feels like the page fighting the user.
  {%- endcomment -%}
  <div class="tamarinse-capsule__steps" aria-hidden="true">
    <span class="tamarinse-capsule__lead" style="height: calc({{ ing_lead }} * var(--capsule-scroll-length, 600vh));"></span>
    {%- for i in (1..ingredient_count) -%}
      <span
        class="tamarinse-capsule__step"
        style="height: calc({{ ing_span }} * var(--capsule-scroll-length, 600vh));"
      ></span>
    {%- endfor -%}
  </div>
</tamarinse-capsule-sequence>

<script src="{{ 'tamarinse-capsule-timeline.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .tamarinse-capsule {
    display: block;
    position: relative;
    background: var(--t-bg);
    color: var(--t-text-hi);
    /* Height now comes from the snap steps below, not a fixed calc, so the
       steps can sit in normal flow and act as real snap targets. */
    --capsule-scroll-length: var(--capsule-scroll-desktop, 600vh);
  }

  /* Phones: longer track, so every ingredient gets more scroll to itself */
  @media screen and (max-width: 749px) {
    .tamarinse-capsule {
      --capsule-scroll-length: var(--capsule-scroll-mobile, 900vh);
    }
  }

  /* ── Snap steps: invisible, carry the scroll length + snap points ── */
  .tamarinse-capsule__steps {
    position: relative;
    z-index: 0;
    /* Same total geometry as before: one viewport of pin + the scrub range */
    height: calc(100svh + var(--capsule-scroll-length, 600vh));
    pointer-events: none;
    /*
      Overlaps the sticky stage so the steps start at the section's top and
      their offsets map directly onto timeline progress.

      This negative margin MUST live here, not as margin-bottom on the sticky
      element: a sticky box's constraint rectangle is its containing block
      shrunk by its own margins, so a negative margin there EXPANDS the
      sticky range and the stage keeps sticking a full viewport past the end
      of the section — covering the top of the next one. Moving the offset to
      this (non-positioned) sibling produces identical geometry with none of
      that side effect.
    */
    margin-block-start: -100svh;
  }

  .tamarinse-capsule__lead,
  .tamarinse-capsule__step {
    display: block;
  }

  .tamarinse-capsule__step {
    scroll-snap-align: start;
    /* The fix for "one flick skips five ingredients" */
    scroll-snap-stop: always;
  }

  /*
    Snap is enabled on TOUCH ONLY, and only while this section is on screen
    (the custom element toggles .t-capsule-snap on the scroll container).
    Desktop pointers are precise and already comfortable, and mandatory snap
    under a mouse wheel reads as the page grabbing you.
  */
  @media (pointer: coarse) {
    :root.t-capsule-snap,
    .page-wrapper.t-capsule-snap {
      scroll-snap-type: y mandatory;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :root.t-capsule-snap,
    .page-wrapper.t-capsule-snap {
      scroll-snap-type: none;
    }
  }

  /* ── Sticky container ── */
  .tamarinse-capsule__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    z-index: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--t-space-xs);
    /* Bottom pad clears the floating buy bar so dots don’t sit on it */
    padding: calc(var(--header-height, 64px) + var(--t-space-xs)) var(--t-space-md)
      calc(5.75rem + env(safe-area-inset-bottom, 0px));
    text-align: center;
  }

  /*
    Full-bleed bottom fade for copy legibility — no radial “blob” that can
    read as a clipped rectangle against the sequence.
  */
  .tamarinse-capsule__sticky::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: min(46svh, 22rem);
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      to top,
      var(--t-bg) 0%,
      color-mix(in srgb, var(--t-bg) 72%, transparent) 38%,
      color-mix(in srgb, var(--t-bg) 28%, transparent) 68%,
      transparent 100%
    );
  }

  /* ── Scroll-scrubbed sequence canvas ── */
  .tamarinse-capsule__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* ── Eyebrow ── */
  /* Doubled class + margin-block-start beat Horizon's base.css reset
     ":first-child:empty + :where(p, …) { margin-block-start: 0 }"
     (the eyebrow is the p right after the empty canvas element). */
  .tamarinse-capsule__eyebrow.tamarinse-capsule__eyebrow {
    position: relative;
    z-index: 5;
    color: var(--t-text-low);
    margin: 0;
    /* Pulled in from the viewport edge, toward the capsule */
    margin-block-start: clamp(1rem, 7svh, 4.5rem);
  }

  /* ── Stage: fills the space over the sequence, hosts the reveal text ── */
  .tamarinse-capsule__stage {
    position: relative;
    flex: 1 1 auto;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  /* ── Reveal area over the sequence ── */
  .tamarinse-capsule__reveal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(92%, 420px);
    display: grid;
    place-items: center;
    z-index: 3;
  }

  .tamarinse-capsule__ingredient {
    grid-area: 1 / 1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--t-space-2xs);
    max-width: var(--t-copy-max);
    opacity: 0;
    transform: translateY(8px);
    /* Default = exit: ease-in-out so copy doesn’t snap away */
    transition:
      opacity 520ms var(--t-ease-in-out),
      transform 520ms var(--t-ease-in-out);
    pointer-events: none;
  }

  /* Soft page-colored halo behind the reveal so the copy stays legible over
     the capsule render's smoke/texture without boxing it in */
  .tamarinse-capsule__ingredient::before {
    content: '';
    position: absolute;
    inset: -1.75rem -2.75rem;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgb(250 246 238 / 0.4), rgb(250 246 238 / 0.25) 55%, transparent);
  }

  .tamarinse-capsule__ingredient[data-active] {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 680ms var(--t-ease-out),
      transform 680ms var(--t-ease-out);
  }

  /* ── Icon badge ── */
  .tamarinse-capsule__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 1px 2px rgb(26 26 26 / 0.08), 0 4px 14px rgb(26 26 26 / 0.12);
    color: var(--t-accent);
    flex-shrink: 0;
    transform: scale(0.5);
    transition: transform 420ms var(--t-ease-in-out);
  }

  .tamarinse-capsule__ingredient[data-active] .tamarinse-capsule__icon {
    transform: scale(1);
    transition: transform 560ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tamarinse-capsule__icon svg {
    width: 22px;
    height: 22px;
  }

  .tamarinse-capsule__ingredient strong {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h3);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-subheading);
    text-wrap: balance;
  }

  .tamarinse-capsule__ingredient em {
    font-style: normal;
    font-size: var(--t-type-body);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    text-wrap: pretty;
    max-width: 30ch;
  }

  /* ── Copy block beneath stage ── */
  /* Layer-one + dots share one cell so they crossfade without a layout jump */
  .tamarinse-capsule__copy {
    position: relative;
    z-index: 5;
    display: grid;
    place-items: center;
    min-height: 4.5rem;
    width: min(100%, var(--t-copy-max));
    /* Extra lift above the buy-bar clearance on the sticky pad */
    margin-bottom: clamp(0.5rem, 4svh, 2rem);
  }

  .tamarinse-capsule__layer-one,
  .tamarinse-capsule__dots {
    grid-area: 1 / 1;
  }

  .tamarinse-capsule__layer-one {
    max-width: var(--t-copy-max);
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    margin: 0;
    opacity: 0;
    transform: translateY(8px);
    text-wrap: pretty;
    pointer-events: none;
    transition:
      opacity 640ms var(--t-ease-in-out),
      transform 640ms var(--t-ease-in-out);
  }

  .tamarinse-capsule__layer-one strong {
    display: block;
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h3);
    font-weight: var(--t-weight-subheading);
    color: var(--t-text-hi);
    margin-block-end: var(--t-space-2xs);
    text-wrap: balance;
  }

  .tamarinse-capsule[data-phase='open'] .tamarinse-capsule__layer-one,
  .tamarinse-capsule[data-static] .tamarinse-capsule__layer-one {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition:
      opacity 700ms var(--t-ease-out),
      transform 700ms var(--t-ease-out);
  }

  /* ── Dots ── */
  .tamarinse-capsule__dots {
    display: flex;
    justify-content: center;
    /* The 44px buttons carry their own spacing now */
    gap: 0;
    opacity: 0;
    transition: opacity 640ms var(--t-ease-in-out);
  }

  /* Hidden dots must not be reachable by keyboard or touch */
  .tamarinse-capsule:not([data-phase='ingredient']):not([data-phase='after']):not([data-static])
    .tamarinse-capsule__dots {
    visibility: hidden;
  }

  .tamarinse-capsule[data-phase='ingredient'] .tamarinse-capsule__dots,
  .tamarinse-capsule[data-phase='after'] .tamarinse-capsule__dots {
    opacity: 1;
    transition: opacity 700ms var(--t-ease-out);
  }

  /* Tappable: a 7px dot inside a full-size touch target */
  .tamarinse-capsule__dot {
    display: grid;
    place-items: center;
    width: var(--t-touch-target);
    height: var(--t-touch-target);
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .tamarinse-capsule__dot::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--t-text-low);
    opacity: 0.35;
    transition:
      opacity var(--t-dur-fast) var(--t-ease-out),
      background var(--t-dur-fast) var(--t-ease-out),
      transform var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-capsule__dot[data-active]::before {
    opacity: 1;
    background: var(--t-accent);
    transform: scale(1.3);
  }

  @media (hover: hover) {
    .tamarinse-capsule__dot:hover::before {
      opacity: 0.7;
    }
  }

  .tamarinse-capsule__dot:focus-visible {
    outline: 2px solid var(--t-accent);
    outline-offset: -6px;
    border-radius: 50%;
  }

  /* ── Reduced motion: static list, no sequence ── */
  .tamarinse-capsule[data-static] {
    height: auto;
  }

  .tamarinse-capsule[data-static] .tamarinse-capsule__sticky {
    position: static;
    height: auto;
    min-height: 100svh;
  }

  /* Static fallback: no pin, so the scroll track and its snap points go */
  .tamarinse-capsule[data-static] .tamarinse-capsule__steps {
    display: none;
  }

  .tamarinse-capsule[data-static] .tamarinse-capsule__canvas {
    display: none;
  }

  .tamarinse-capsule[data-static] .tamarinse-capsule__ingredient {
    position: static;
    opacity: 1;
    transform: none;
  }

  .tamarinse-capsule[data-static] .tamarinse-capsule__icon {
    transform: scale(1);
  }

  .tamarinse-capsule[data-static] .tamarinse-capsule__reveal {
    position: static;
    transform: none;
    width: auto;
    display: flex;
    flex-direction: column;
    gap: var(--t-space-md);
    padding: var(--t-space-md) 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse Capsule",
  "tag": "section",
  "class": "tamarinse-capsule-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Inside the capsule"
    },
    {
      "type": "text",
      "id": "layer_one_title",
      "label": "Layer one title",
      "default": "Delayed-Release Capsule"
    },
    {
      "type": "textarea",
      "id": "layer_one_text",
      "label": "Layer one text",
      "default": "Designed to bypass stomach acid before releasing its ingredients where they're intended to work."
    },
    {
      "type": "metaobject_list",
      "id": "ingredients",
      "label": "Ingredients (metaobject)",
      "metaobject_type": "ingredient",
      "info": "When connected, these replace the ingredient blocks below so all sections share one editable list."
    },
    {
      "type": "range",
      "id": "scroll_length",
      "label": "Sequence scroll distance",
      "min": 200,
      "max": 900,
      "step": 50,
      "unit": "vh",
      "default": 600,
      "info": "Total scroll the section holds for. Higher = each ingredient gets more scroll distance, so the reveals read slower and calmer."
    },
    {
      "type": "range",
      "id": "mobile_scroll_boost",
      "label": "Mobile scroll multiplier",
      "min": 100,
      "max": 250,
