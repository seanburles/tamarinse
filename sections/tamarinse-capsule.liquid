          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Fenugreek Extract",
            "description": "A source of soluble galactomannan polysaccharides."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Activated Coconut Charcoal",
