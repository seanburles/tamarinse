{% comment %}
  Meet Tamarinse (MASTER_PROMPT #5) — large static bottle render, subtle
  hover animation, physician-formulated positioning statement (CONTENT.md).
{% endcomment %}

<section class="tamarinse-meet" id="TamarinseMeet-{{ section.id }}">
  <div class="tamarinse-meet__inner">
    <div class="tamarinse-meet__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 750px) 44vw, 86vw',
            class: 'tamarinse-meet__image',
            loading: 'lazy',
            alt: section.settings.image.alt
        }}
      {%- else -%}
        {%- comment -%}
          Trimmed copy of the hires photo (whitespace cropped to the bottle,
          24px breathing room) so the bottle fills the media column.
        {%- endcomment -%}
        <img
          src="{{ 'tamarinse-bottle-photo-trimmed.webp' | asset_url }}"
          class="tamarinse-meet__image"
          alt="Tamarinse™ bottle"
          width="543"
          height="1053"
          loading="lazy"
        >
      {%- endif -%}
    </div>
    <div class="tamarinse-meet__content">
      <p class="t-eyebrow t-eyebrow--ruled-both tamarinse-meet__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tamarinse-meet__title">{{ section.settings.title }}</h2>
      <p class="tamarinse-meet__text">{{ section.settings.text }}</p>
      {%- if section.settings.cta_label != blank -%}
        {%- capture tamarinse_shop_url -%}{% render 'tamarinse-shop-url' %}{%- endcapture -%}
        <a class="t-btn t-btn--ghost" href="{{ section.settings.cta_link | default: tamarinse_shop_url }}">
          {{- section.settings.cta_label -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .tamarinse-meet {
    display: block;
    background: var(--t-tint);
    color: var(--t-text-hi);
    padding: var(--t-space-section) var(--t-space-md);
  }

  .tamarinse-meet__inner {
    max-width: var(--t-content-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--t-space-xl);
    align-items: center;
  }

  .tamarinse-meet__media {
    /* The trimmed render is nearly all bottle — narrower column, same presence */
    width: min(62vw, 330px);
  }

  .tamarinse-meet__image {
    width: 100%;
    height: auto;
    mix-blend-mode: multiply;
    transition: transform var(--t-dur-slow) var(--t-ease-out);
  }

  @media (hover: hover) {
    .tamarinse-meet__media:hover .tamarinse-meet__image {
      transform: translateY(-8px);
    }
  }

  .tamarinse-meet__content {
    max-width: var(--t-copy-max);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--t-space-sm);
  }

  .tamarinse-meet__eyebrow {
    color: var(--t-text-low);
    margin: 0;
  }

  .tamarinse-meet__title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    margin: 0;
    text-wrap: balance;
  }

  .tamarinse-meet__text {
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    margin: 0 0 var(--t-space-sm);
  }

  @media screen and (min-width: 990px) {
    .tamarinse-meet__inner {
      flex-direction: row;
      justify-content: center;
      gap: var(--t-space-2xl);
    }

    .tamarinse-meet__content {
      text-align: left;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse Meet",
  "tag": "section",
  "class": "tamarinse-meet-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bottle render"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Meet Tamarinse™"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Physician formulated. Built for modern exposure."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Tamarinse is the first premium supplement built around tamarind seed extract for daily environmental defense. Our formula combines five plant-based ingredients designed to support your body's natural detoxification pathways and digestive elimination. 60 capsules per bottle. 30-day supply."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Tamarinse™"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Tamarinse Meet",
      "category": "Tamarinse"
    }
  ]
}
{% endschema %}
