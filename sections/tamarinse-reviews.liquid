{% comment %}
  Reviews (MASTER_PROMPT #13) — luxury layout. Badge (rating/count/source) is
  section settings; each review is an editable block, swappable for real
  reviews or a review-app feed with no code change (BUILD_GUIDE section 8).
  Default quotes and the 4.8/4,000+ badge are reused verbatim from the
  client's published "What Our Customers Say" section on tamarinse.com.
{% endcomment %}

<section class="tamarinse-reviews t-on-light" id="TamarinseReviews-{{ section.id }}">
  <div class="tamarinse-reviews__inner">
    <header class="tamarinse-reviews__header">
      <p class="t-eyebrow tamarinse-reviews__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tamarinse-reviews__title">{{ section.settings.title }}</h2>

      {%- if section.settings.show_badge -%}
        {%- render 'tamarinse-reviews-badge',
          rating: section.settings.badge_rating,
          count: section.settings.badge_count,
          source: section.settings.badge_source
        -%}
      {%- endif -%}
    </header>

    <div class="tamarinse-reviews__grid">
      {%- for block in section.blocks -%}
        <figure class="tamarinse-reviews__card" {{ block.shopify_attributes }}>
          <span class="tamarinse-reviews__deco" aria-hidden="true">&ldquo;</span>
          <div class="tamarinse-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span class="tamarinse-reviews__star{% if i > block.settings.rating %} tamarinse-reviews__star--empty{% endif %}" aria-hidden="true">&#9733;</span>
            {%- endfor -%}
          </div>
          <blockquote class="tamarinse-reviews__quote">{{ block.settings.quote }}</blockquote>
          <figcaption class="tamarinse-reviews__attribution">
            <span class="tamarinse-reviews__avatar" aria-hidden="true">{{ block.settings.name | slice: 0 }}</span>
            <span class="tamarinse-reviews__meta">
              <span class="tamarinse-reviews__name">{{ block.settings.name }}</span>
              {%- if block.settings.role != blank -%}
                <span class="tamarinse-reviews__role">
                  <svg class="tamarinse-reviews__check" width="12" height="12" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"/></svg>
                  {{ block.settings.role -}}
                </span>
              {%- endif -%}
            </span>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .tamarinse-reviews {
    display: block;
    background: var(--t-tint);
    color: var(--t-text-hi);
    padding: var(--t-space-section) var(--t-space-md);
  }

  .tamarinse-reviews__inner {
    max-width: var(--t-content-max);
    margin-inline: auto;
  }

  .tamarinse-reviews__header {
    max-width: var(--t-copy-max);
    margin-block-end: var(--t-space-xl);
  }

  .tamarinse-reviews__eyebrow {
    color: var(--t-text-low);
    margin: 0 0 var(--t-space-sm);
  }

  .tamarinse-reviews__title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    margin: 0 0 var(--t-space-sm);
    text-wrap: balance;
  }

  .tamarinse-reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--t-space-sm);
  }

  .tamarinse-reviews__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin: 0;
    padding: var(--t-space-md) var(--t-space-md) var(--t-space-sm);
    background: var(--t-card);
    border: 1px solid var(--t-border);
    border-radius: var(--t-radius-sm);
    border-top: 3px solid var(--t-accent);
    overflow: hidden;
  }

  .tamarinse-reviews__deco {
    position: absolute;
    top: -0.15em;
    right: var(--t-space-sm);
    font-family: var(--t-font-heading);
    font-size: 5rem;
    line-height: 1;
    color: var(--t-accent);
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
  }

  .tamarinse-reviews__stars {
    color: var(--t-accent-2);
    letter-spacing: 0.15em;
    font-size: 0.75rem;
  }

  .tamarinse-reviews__star--empty {
    opacity: 0.25;
  }

  .tamarinse-reviews__quote {
    font-size: var(--t-type-small);
    line-height: 1.55;
    margin: 0;
    color: var(--t-text-mid);
    text-wrap: pretty;
  }

  .tamarinse-reviews__attribution {
    margin-block-start: auto;
    padding-block-start: 0.625rem;
    border-top: 1px solid var(--t-border);
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .tamarinse-reviews__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--t-accent);
    color: #fff;
    font-family: var(--t-font-heading);
    font-size: var(--t-type-eyebrow);
    font-weight: var(--t-weight-semibold);
    line-height: 1;
    flex-shrink: 0;
  }

  .tamarinse-reviews__meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .tamarinse-reviews__name {
    font-size: var(--t-type-eyebrow);
    font-weight: var(--t-weight-semibold);
    line-height: 1.3;
  }

  .tamarinse-reviews__role {
    font-size: var(--t-type-eyebrow);
    color: var(--t-text-low);
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .tamarinse-reviews__check {
    color: var(--t-accent);
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .tamarinse-reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .tamarinse-reviews__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse Reviews",
  "tag": "section",
  "class": "tamarinse-reviews-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Trusted daily. Reviewed honestly."
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show rating badge",
      "default": true
    },
    {
      "type": "range",
      "id": "badge_rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 4.8
    },
    {
      "type": "number",
      "id": "badge_count",
      "label": "Review count",
      "default": 4000
    },
    {
      "type": "text",
      "id": "badge_source",
      "label": "Source label",
      "default": "customer reviews",
      "info": "Swap for the review platform name (Judge.me, Okendo, Loox) when a real feed is connected."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role (e.g. Physician review, Verified buyer)"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tamarinse Reviews",
      "category": "Tamarinse",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "Glass bottle, clean ingredients, transparent label. This is what a modern supplement should look like. Three months in and reordering was easy.",
            "name": "J.",
            "role": "Verified buyer",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "I kept hearing about tamarind for microplastics but couldn't find a product built around it. Tamarinse just made sense. Clean formula I can actually understand.",
            "name": "S.",
            "role": "Verified buyer",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "The first supplement that feels thoughtful and intentional. Built around tamarind with a clear reason for existing — not just another generic capsule.",
            "name": "L.",
            "role": "Verified buyer",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
