
{{ 'tamarinse-blog.css' | asset_url | stylesheet_tag }}

<script
  src="{{ 'blog-posts-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<blog-posts-list section-id="{{ section.id }}">
  <div
    class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  ></div>
  <div
    class="
      section
      {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
      blog-posts
      spacing-style
      size-style
    "
    data-testid="blog-posts"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {% content_for 'blocks' %}

    <div
      ref="grid"
      class="blog-posts-container"
    >
      {% for article in blog.articles %}
        {% liquid
          # Calm editorial: one featured lead, then an even 2-column grid
          assign col_span = 3
          assign scale = 0.9
          assign is_horizontal = false

          if forloop.first
            assign col_span = 6
            assign scale = 1
            assign is_horizontal = true
          endif
        %}
        {% style %}
          [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
            --col-span: {{ col_span }};
            --blog-post-card-scale: {{ scale }};
          }

          @media screen and (max-width: 749px) {
            [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
              --col-span: 6;
              --blog-post-card-scale: 0.9;
            }
          }
        {% endstyle %}
        <div
          class="blog-post-item{% if is_horizontal %} blog-post-item--horizontal{% endif %}"
          data-testid="blog-post-item"
          data-blog-index="{{ section.id }}-{{ forloop.index }}"
        >
          {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
        </div>
      {% endfor %}
    </div>
  </div>
</blog-posts-list>

{% stylesheet %}
  .blog-posts-container {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    width: 100%;
    column-gap: var(--columns-gap);
    row-gap: var(--rows-gap);
  }

  .blog-post-item {
    grid-column: span var(--col-span);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_posts",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
