{% comment %}
  Everyday Exposure (MASTER_PROMPT #12) — lifestyle photography, one message.
  Scroll-pinned card-deck reveal shared with The Problem (style contract:
  no collage grids in these two sections; shared machinery lives in
  tamarinse-panel-stack.js/.css). Blocks are individual photographs from the
  client brief's shot list; the single message introduces the deck once.
{% endcomment %}

{{ 'tamarinse-panel-stack.css' | asset_url | stylesheet_tag }}

<section class="tamarinse-everyday" id="TamarinseEveryday-{{ section.id }}">
  <tamarinse-panel-stack
    style="--stack-count: {{ section.blocks.size }};"
    {% if section.settings.slide_direction == 'side' %}data-direction="horizontal"{% endif %}
  >
    <div class="t-stack__sticky">
      {%- comment -%}
        The section message rides on top of the deck itself — pinned over
        every card so the photos read as one continuous statement.
      {%- endcomment -%}
      <span class="tamarinse-everyday__top-scrim" aria-hidden="true"></span>
      <h2 class="tamarinse-everyday__deck-title{% unless section.settings.animate_title %} tamarinse-everyday__deck-title--static{% endunless %}">
        <span>{{ section.settings.message }}</span>
      </h2>

      {%- for block in section.blocks -%}
        {%- liquid
          # A merchant-picked image wins; otherwise fall back to a bundled theme
          # asset (image_picker settings cannot reference theme assets directly).
          assign has_photo = false
          if block.settings.image != blank or block.settings.asset_fallback != blank
            assign has_photo = true
          endif
        -%}
        <div class="t-stack__card tamarinse-everyday__card{% cycle ' ', ' tamarinse-everyday__card--alt' %}" data-stack-card {{ block.shopify_attributes }}>
          <div class="t-stack__media" aria-hidden="{% if has_photo %}false{% else %}true{% endif %}">
            {%- if block.settings.image != blank -%}
              <picture>
                {%- if block.settings.image_mobile != blank -%}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ block.settings.image_mobile | image_url: width: 500 }} 500w,
                      {{ block.settings.image_mobile | image_url: width: 800 }} 800w,
                      {{ block.settings.image_mobile | image_url: width: 1200 }} 1200w
                    "
                    sizes="100vw"
                    width="{{ block.settings.image_mobile.width }}"
                    height="{{ block.settings.image_mobile.height }}"
                  >
                {%- endif -%}
                {{
                  block.settings.image
                  | image_url: width: 2560
                  | image_tag:
                    widths: '832, 1200, 1600, 1920, 2560',
                    sizes: '100vw',
                    loading: 'lazy',
                    alt: block.settings.image.alt
                }}
              </picture>
            {%- elsif block.settings.asset_fallback != blank -%}
              <img
                src="{{ block.settings.asset_fallback | asset_url }}"
                alt=""
                width="1820"
                height="1024"
                loading="lazy"
              >
            {%- else -%}
              <div class="tamarinse-everyday__placeholder">
                <span>{{ block.settings.caption | default: 'Photography pending' }}</span>
              </div>
            {%- endif -%}
          </div>
          {%- if has_photo -%}
            <span class="t-stack__scrim" aria-hidden="true"></span>
          {%- endif -%}
          {%- if block.settings.caption != blank or block.settings.headline != blank or block.settings.detail != blank -%}
            <div class="t-stack__copy tamarinse-everyday__copy">
              {%- if block.settings.caption != blank -%}
                <p class="t-eyebrow t-eyebrow--ruled t-stack-reveal tamarinse-everyday__eyebrow" style="--sr-delay: 0.5;">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if block.settings.headline != blank -%}
                <h3 class="tamarinse-everyday__headline t-stack-reveal" style="--sr-delay: 0.62;">{{ block.settings.headline }}</h3>
              {%- endif -%}
              {%- if block.settings.detail != blank -%}
                <p class="tamarinse-everyday__detail t-stack-reveal" style="--sr-delay: 0.74;">{{ block.settings.detail }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="t-stack__progress" aria-hidden="true">
        <span class="t-stack__count">
          <span data-stack-index>01</span>
          <span class="t-stack__count-total">{{ section.blocks.size | prepend: '0' | slice: -2, 2 }}</span>
        </span>
        {%- for block in section.blocks -%}
          <span class="t-stack__tick" data-stack-tick{% if forloop.first %} data-active{% endif %}></span>
        {%- endfor -%}
      </div>
    </div>
  </tamarinse-panel-stack>
</section>

<script src="{{ 'tamarinse-panel-stack.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .tamarinse-everyday {
    display: block;
    background: var(--t-bg);
    color: var(--t-text-hi);
  }

  /* Shade weighted to the top-left corner, where the pinned title now sits,
     so it stays legible over bright skies, windows, and steam */
  .tamarinse-everyday__top-scrim {
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 48%;
    z-index: 4;
    background:
      radial-gradient(130% 115% at 0% 0%, rgb(16 20 18 / 68%), rgb(16 20 18 / 30%) 55%, transparent 78%),
      linear-gradient(to bottom, rgb(16 20 18 / 35%), transparent 70%);
    pointer-events: none;
  }

  /* Pinned deck title — a left-anchored statement over every card.
     Same choreography as The Problem's pinned title (shared treatment,
     client 2026-07-18): rises in over the first ~6% of the pin, rides over
     every card, lifts away as the LAST card arrives (exit point derived
     from --stack-count). The --static modifier (section checkbox) opts out
     and simply keeps it pinned. */
  .tamarinse-everyday__deck-title {
    position: absolute;
    z-index: 5;
    inset-inline: var(--t-space-md);
    top: calc(var(--header-height, 64px) + var(--t-space-md));
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    text-align: left;
    max-width: 14ch;
    color: var(--t-photo-text);
    margin: 0;
    text-wrap: balance;
    pointer-events: none;
    --intro-in: clamp(0, calc(var(--stack-progress, 0) / 0.06), 1);
    --intro-exit-start: calc((var(--stack-count, 3) - 2) / (var(--stack-count, 3) - 1));
    --intro-out: clamp(
      0,
      calc((var(--stack-progress, 0) - var(--intro-exit-start)) / 0.14),
      1
    );
    opacity: calc(var(--intro-in) * (1 - var(--intro-out)));
  }

  .tamarinse-everyday__deck-title span {
    display: block;
    transform: translateY(calc((1 - var(--intro-in)) * 1.75rem - var(--intro-out) * 2rem));
  }

  .tamarinse-everyday__deck-title--static {
    opacity: 1;
  }

  .tamarinse-everyday__deck-title--static span {
    transform: none;
  }

  @media (min-width: 990px) {
    .tamarinse-everyday__deck-title {
      inset-inline-start: clamp(2rem, 5vw, 4.5rem);
    }
  }

  .tamarinse-everyday__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--t-text-low);
    font-size: var(--t-type-small);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-block: 1px solid var(--t-border);
  }

  /* Editorial copy block — eyebrow names the moment, headline names the
     exposure, detail explains it. Sits on the scrim like The Problem's stats
     so the two sections read as one photographic essay. */
  .tamarinse-everyday__eyebrow {
    color: var(--t-photo-text-mid);
    margin: 0 0 var(--t-space-2xs);
  }

  .tamarinse-everyday__headline {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h3);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    color: var(--t-photo-text);
    max-width: 24ch;
    margin: 0 0 var(--t-space-2xs);
    text-wrap: balance;
  }

  .tamarinse-everyday__detail {
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    color: var(--t-photo-text-mid);
    max-width: 44ch;
    margin: 0;
    text-wrap: pretty;
  }

  /* Alternate the copy to the right on even photos so the sequence has a
     back-and-forth reading rhythm instead of a repeated template. */
  @media (min-width: 990px) {
    .tamarinse-everyday__card--alt .tamarinse-everyday__copy {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
      /* Keep clear of the progress rail on the right edge */
      padding-inline-end: clamp(3.5rem, 7vw, 6rem);
    }

    /* Mirror the eyebrow rule so it trails the label on right-aligned panels */
    .tamarinse-everyday__card--alt .tamarinse-everyday__eyebrow {
      flex-direction: row-reverse;
    }
  }

  /* Static fallback (reduced motion, or the custom element never loaded):
     the deck renders as a plain stacked flow, so the title becomes a normal
     heading above the photos and the shade strip disappears. */
  tamarinse-panel-stack[data-static] .tamarinse-everyday__top-scrim,
  tamarinse-panel-stack:not(:defined) .tamarinse-everyday__top-scrim {
    display: none;
  }

  tamarinse-panel-stack[data-static] .tamarinse-everyday__deck-title,
  tamarinse-panel-stack:not(:defined) .tamarinse-everyday__deck-title {
    position: static;
    color: var(--t-text-hi);
    padding: var(--t-space-xl) var(--t-space-md) var(--t-space-lg);
    opacity: 1;
  }

  tamarinse-panel-stack[data-static] .tamarinse-everyday__deck-title span,
  tamarinse-panel-stack:not(:defined) .tamarinse-everyday__deck-title span {
    transform: none;
  }

  /* Placeholder panels (no photo, no scrim): keep the copy legible on light */
  .tamarinse-everyday__card:not(:has(.t-stack__scrim)) .tamarinse-everyday__eyebrow {
    color: var(--t-text-low);
  }

  .tamarinse-everyday__card:not(:has(.t-stack__scrim)) .tamarinse-everyday__headline {
    color: var(--t-text-hi);
  }

  .tamarinse-everyday__card:not(:has(.t-stack__scrim)) .tamarinse-everyday__detail {
    color: var(--t-text-mid);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Everyday Exposure",
  "tag": "section",
  "class": "tamarinse-everyday-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Exposure happens every day."
    },
    {
      "type": "select",
      "id": "slide_direction",
      "label": "Card slide direction",
      "options": [
        { "value": "up", "label": "Bottom to top" },
        { "value": "side", "label": "Left to right" }
      ],
      "default": "up",
      "info": "The product page uses left to right as a variation on the homepage."
    },
    {
      "type": "checkbox",
      "id": "animate_title",
      "label": "Animate pinned title",
      "default": true,
      "info": "On: the title rises in as the section pins and lifts away at the last card. Off: it simply stays pinned."
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photograph",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (landscape, desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (portrait crop, mobile)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Eyebrow",
          "info": "Short label naming the moment (e.g. \"At home\")."
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "info": "Names the exposure in the photo."
        },
        {
          "type": "textarea",
          "id": "detail",
          "label": "Supporting detail",
          "info": "One or two sentences explaining what's happening."
        },
        {
          "type": "text",
          "id": "asset_fallback",
          "label": "Bundled photo filename",
          "info": "Theme asset used until a real image is picked above (e.g. tamarinse-photo-lunch.webp)."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Everyday Exposure",
      "category": "Tamarinse",
      "blocks": [
        {
          "type": "photo",
          "settings": {
            "caption": "At home",
            "headline": "Plastic wrap. Cutting boards. Storage containers.",
            "detail": "Everyday food prep sheds microscopic plastic particles straight into the meals you make for your family.",
            "asset_fallback": "tamarinse-photo-lunch.webp"
          }
        },
        {
          "type": "photo",
          "settings": {
            "caption": "Your morning coffee",
            "headline": "A hot drink through a plastic-lined lid.",
            "detail": "Most single-use cups and lids are lined with polyethylene — and heat helps particles migrate into your drink.",
            "asset_fallback": "tamarinse-photo-coffee.webp"
          }
        },
        {
          "type": "photo",
          "settings": {
            "caption": "Dinner on the go",
            "headline": "Hot food, plastic containers.",
            "detail": "Takeout packaging in direct contact with hot food is one of the most common exposure routes of all.",
            "asset_fallback": "tamarinse-photo-takeout.webp"
          }
        }
      ]
    }
  ]
}
{% endschema %}
