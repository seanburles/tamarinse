            "credentials": "California, USA",
            "portrait_asset": "tamarinse-advisor-gupta.png"
          }
        },
        {
          "type": "member",
          "settings": {
            "name": "Dr. Jones",
            "credentials": "Maryland, USA",
            "portrait_asset": "tamarinse-advisor-jones.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}
