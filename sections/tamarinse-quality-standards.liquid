{% comment %}
  Quality Standards (MASTER_PROMPT #9) — minimalist icon row.
  Phosphor duotone icons (MIT, phosphoricons.com) in the accent green,
  matching the quiz answer cards. Each standard is a block: label + icon
  choice or custom image.
{% endcomment %}

<section class="tamarinse-quality t-on-light" id="TamarinseQuality-{{ section.id }}">
  <h2 class="visually-hidden">{{ section.settings.title }}</h2>
  <ul class="tamarinse-quality__row">
    {%- for block in section.blocks -%}
      <li class="tamarinse-quality__item" {{ block.shopify_attributes }}>
        <span class="tamarinse-quality__icon" aria-hidden="true">
          {%- if block.settings.custom_icon != blank -%}
            {{ block.settings.custom_icon | image_url: width: 96 | image_tag: class: 'tamarinse-quality__icon-image', alt: '' }}
          {%- else -%}
            {%- case block.settings.icon -%}
              {%- when 'leaf' -%}
                {%- comment -%} Solid two-leaf "100% natural" mark (client ref. badge sheet) {%- endcomment -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><path d="M120 150C58 140 28 98 38 38c62 14 92 60 84 112Z"/><path d="M136 146c-4-50 24-94 74-104 8 60-24 100-72 108Z"/><path d="M128 224c-4-30-2-52 0-74" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round"/></svg>
              {%- when 'stethoscope' -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><path d="M240,160a32,32,0,1,1-32-32A32,32,0,0,1,240,160Z" opacity="0.2"/><path d="M220,160a12,12,0,1,1-12-12A12,12,0,0,1,220,160Zm-4.55,39.29A48.08,48.08,0,0,1,168,240H144a48.05,48.05,0,0,1-48-48V151.49A64,64,0,0,1,40,88V40a8,8,0,0,1,8-8H72a8,8,0,0,1,0,16H56V88a48,48,0,0,0,48.64,48c26.11-.34,47.36-22.25,47.36-48.83V48H136a8,8,0,0,1,0-16h24a8,8,0,0,1,8,8V87.17c0,32.84-24.53,60.29-56,64.31V192a32,32,0,0,0,32,32h24a32.06,32.06,0,0,0,31.22-25,40,40,0,1,1,16.23.27ZM232,160a24,24,0,1,0-24,24A24,24,0,0,0,232,160Z"/></svg>
              {%- when 'flask' -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><path d="M208,216H48a8,8,0,0,1-6.86-12.12l30.48-50.8h0c13.23-2.48,32-1.41,56.37,10.92,32.25,16.33,54.75,12.91,67.5,7.65h0l19.34,32.23A8,8,0,0,1,208,216Z" opacity="0.2"/><path d="M221.69,199.77,160,96.92V40h8a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8V96.92L34.31,199.77A16,16,0,0,0,48,224H208a16,16,0,0,0,13.72-24.23ZM110.86,103.25A7.93,7.93,0,0,0,112,99.14V40h32V99.14a7.93,7.93,0,0,0,1.14,4.11L183.36,167c-12,2.37-29.07,1.37-51.75-10.11-15.91-8.05-31.05-12.32-45.22-12.81ZM48,208l28.54-47.58c14.25-1.73,30.31,1.85,47.82,10.72,19,9.61,35,12.88,48,12.88a69.89,69.89,0,0,0,19.55-2.7L208,208Z"/></svg>
              {%- when 'flag' -%}
                {%- comment -%} Waving stars-and-stripes (client ref. "Made in the USA" badge) {%- endcomment -%}
                <svg viewBox="0 0 256 256" fill="none" stroke="currentColor" stroke-width="11" stroke-linecap="round"><path d="M44 70q26-14 52 0t52 0q26-14 52 0"/><path d="M44 92q26-14 52 0t52 0q26-14 52 0"/><path d="M44 114q26-14 52 0t52 0q26-14 52 0"/><path d="M44 136q26-14 52 0t52 0q26-14 52 0"/><path d="M44 158q26-14 52 0t52 0q26-14 52 0"/><path d="M44 180q26-14 52 0t52 0q26-14 52 0"/><path fill-rule="evenodd" fill="currentColor" stroke="none" d="M38 56h80v66H38Zm18 14a5 5 0 1 0 0.1 0Zm22 0a5 5 0 1 0 0.1 0Zm22 0a5 5 0 1 0 0.1 0Zm-33 22a5 5 0 1 0 0.1 0Zm22 0a5 5 0 1 0 0.1 0Zm-33 22a5 5 0 1 0 0.1 0Zm22 0a5 5 0 1 0 0.1 0Zm22 0a5 5 0 1 0 0.1 0Z"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><path d="M216,56v56c0,96-88,120-88,120S40,208,40,112V56a8,8,0,0,1,8-8H208A8,8,0,0,1,216,56Z" opacity="0.2"/><path d="M208,40H48A16,16,0,0,0,32,56v56c0,52.72,25.52,84.67,46.93,102.19,23.06,18.86,46,25.26,47,25.53a8,8,0,0,0,4.2,0c1-.27,23.91-6.67,47-25.53C198.48,196.67,224,164.72,224,112V56A16,16,0,0,0,208,40Zm0,72c0,37.07-13.66,67.16-40.6,89.42A129.3,129.3,0,0,1,128,223.62a128.25,128.25,0,0,1-38.92-21.81C61.82,179.51,48,149.3,48,112l0-56,160,0ZM82.34,141.66a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32l-56,56a8,8,0,0,1-11.32,0Z"/></svg>
              {%- when 'asclepius' -%}
                {%- comment -%} Rod of Asclepius — the official medical seal mark (client ref. "Physician Formulated" badge) {%- endcomment -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><circle cx="128" cy="26" r="12"/><rect x="122" y="42" width="12" height="178" rx="6"/><path d="M86 66C154 70 176 88 130 98 84 108 84 126 130 136 176 146 176 164 130 174 102 180 94 194 104 208" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round"/><circle cx="82" cy="64" r="9"/></svg>
              {%- when 'fda' -%}
                {%- comment -%} FDA lettermark (client ref. "FDA Inspected Facility" badge) — pair only with facility/registration wording the client can substantiate {%- endcomment -%}
                <svg viewBox="0 0 256 256"><text x="128" y="166" text-anchor="middle" font-family="'Hanken Grotesk', system-ui, sans-serif" font-weight="800" font-size="102" letter-spacing="-3" fill="currentColor">FDA</text></svg>
              {%- when 'medal' -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><path d="M176,88a48,48,0,1,1-48-48A48,48,0,0,1,176,88Z" opacity="0.2"/><path d="M216,96A88,88,0,1,0,72,163.83V240a8,8,0,0,0,11.58,7.16L128,225l44.43,22.21A8.07,8.07,0,0,0,176,248a8,8,0,0,0,8-8V163.83A87.85,87.85,0,0,0,216,96ZM56,96a72,72,0,1,1,72,72A72.08,72.08,0,0,1,56,96ZM168,227.06l-36.43-18.21a8,8,0,0,0-7.16,0L88,227.06V174.37a87.89,87.89,0,0,0,80,0ZM128,152A56,56,0,1,0,72,96,56.06,56.06,0,0,0,128,152Zm0-96A40,40,0,1,1,88,96,40,40,0,0,1,128,56Z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 256 256" fill="currentColor"><path d="M224,128a96,96,0,1,1-96-96A96,96,0,0,1,224,128Z" opacity="0.2"/><path d="M173.66,98.34a8,8,0,0,1,0,11.32l-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35A8,8,0,0,1,173.66,98.34ZM232,128A104,104,0,1,1,128,24,104.11,104.11,0,0,1,232,128Zm-16,0a88,88,0,1,0-88,88A88.1,88.1,0,0,0,216,128Z"/></svg>
            {%- endcase -%}
          {%- endif -%}
        </span>
        <span class="tamarinse-quality__label">{{ block.settings.label }}</span>
      </li>
    {%- endfor -%}
  </ul>
</section>

{% stylesheet %}
  .tamarinse-quality {
    display: block;
    background: var(--t-tint);
    color: var(--t-text-hi);
    padding: var(--t-space-xl) var(--t-space-md);
    border-block: 1px solid var(--t-border);
  }

  .tamarinse-quality__row {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: var(--t-content-max);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--t-space-lg) var(--t-space-md);
  }

  .tamarinse-quality__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--t-space-sm);
    text-align: center;
  }

  /* Engraved certification-badge chrome (client ref. badge sheet,
     2026-07-18): a heavier outer ring with an inner hairline, sized up so
     the marks read as real seals rather than UI glyphs. */
  .tamarinse-quality__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1.5px solid rgb(13 122 63 / 45%);
    outline: 1px solid rgb(13 122 63 / 20%);
    outline-offset: -6px;
    color: var(--t-accent);
    background: var(--t-accent-tint);
    transition:
      background-color var(--t-dur-fast) var(--t-ease-out),
      border-color var(--t-dur-fast) var(--t-ease-out),
      color var(--t-dur-fast) var(--t-ease-out);
  }

  /* Hovering a certification fills its ring — solid green, white glyph */
  @media (hover: hover) {
    .tamarinse-quality__item:hover .tamarinse-quality__icon {
      background: var(--t-accent);
      border-color: var(--t-accent);
      color: var(--t-white);
    }
  }

  /* Hover fill would swallow the inner hairline — lift it too */
  @media (hover: hover) {
    .tamarinse-quality__item:hover .tamarinse-quality__icon {
      outline-color: rgb(255 255 255 / 35%);
    }
  }

  .tamarinse-quality__icon svg,
  .tamarinse-quality__icon-image {
    width: 34px;
    height: 34px;
  }

  .tamarinse-quality__label {
    font-size: var(--t-type-eyebrow);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: var(--t-weight-semibold);
    color: var(--t-text-mid);
    max-width: 12ch;
  }

  @media screen and (min-width: 750px) {
    .tamarinse-quality__row {
      grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
      column-gap: 0;
    }

    .tamarinse-quality__item {
      padding-inline: var(--t-space-sm);
    }

    /* Hairline dividers between certifications, as on the brand poster */
    .tamarinse-quality__item + .tamarinse-quality__item {
      border-inline-start: 1px solid var(--t-border);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Quality Standards",
  "tag": "section",
  "class": "tamarinse-quality-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Accessible section title",
      "default": "Quality standards"
    }
  ],
  "blocks": [
    {
      "type": "standard",
      "name": "Standard",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Natural leaves" },
            { "value": "stethoscope", "label": "Stethoscope" },
            { "value": "asclepius", "label": "Medical staff (Rod of Asclepius)" },
            { "value": "flask", "label": "Flask" },
            { "value": "flag", "label": "US flag" },
            { "value": "fda", "label": "FDA lettermark" },
            { "value": "shield", "label": "Shield check" },
            { "value": "medal", "label": "Award medal" },
            { "value": "check", "label": "Circle check" }
          ],
          "default": "check"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon (overrides)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Quality Standards",
      "category": "Tamarinse",
      "blocks": [
        { "type": "standard", "settings": { "label": "USDA Organic", "icon": "leaf" } },
        { "type": "standard", "settings": { "label": "Physician Formulated", "icon": "stethoscope" } },
        { "type": "standard", "settings": { "label": "Clinically Studied Ingredients", "icon": "flask" } },
        { "type": "standard", "settings": { "label": "Manufactured in the USA", "icon": "flag" } },
        { "type": "standard", "settings": { "label": "Third-Party Tested (when available)", "icon": "shield" } }
      ]
    }
  ]
}
{% endschema %}
