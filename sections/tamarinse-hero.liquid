{% comment %}
  Tamarinse Hero — pinned opener (client rev. 2026-07-18).
  The section is a tall scroll track with a sticky full-viewport stage:
  scrolling scrubs the bottle turntable, and the hero holds on screen until
  the bottle completes one full rotation ("scroll-jack" via CSS sticky —
  no wheel/touch hijacking, so accessibility and momentum stay native).
  All copy is editable; defaults come from CONTENT.md.
{% endcomment %}

<section
  class="tamarinse-hero"
  id="TamarinseHero-{{ section.id }}"
  style="--t-bottle-period: {{ section.settings.rotation_seconds }}s; --hero-scroll-length: {{ section.settings.scroll_length | default: 90 }}vh;"
>
  <div class="tamarinse-hero__sticky">
    <div class="tamarinse-hero__inner">
    <div class="tamarinse-hero__content">
      {%- if section.settings.award_text != blank -%}
        {%- comment -%}
          Award lockup — set like an engraving instead of a promo chip. An
          em-dash in the setting splits it into a quiet lead line and a
          laurel-flanked prize line (festival-laurel style); without a dash
          the whole text sits between the laurels.
        {%- endcomment -%}
        {%- assign award_parts = section.settings.award_text | split: '—' -%}
        <p class="tamarinse-hero__award">
          {%- if award_parts.size == 2 -%}
            <span class="tamarinse-hero__award-lead">{{ award_parts[0] | strip }}</span>
          {%- endif -%}
          <span class="tamarinse-hero__award-main">
            <svg class="tamarinse-hero__laurel" viewBox="0 0 22 30" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" aria-hidden="true">
              <path d="M19 29 C11.5 25 8 17 9.5 2.5"/>
              <path d="M9.5 3 C6 4.5 4 7.5 4 11"/>
              <path d="M9 8.5 C5.5 10 3.5 13 3.5 16.5"/>
              <path d="M9.5 14 C6.5 15.5 5 18.5 5.5 22"/>
              <path d="M11 19.5 C8.5 21 7.5 24 8.5 27"/>
              <path d="M9.5 3 C12.5 5 14 8 13.5 11.5"/>
              <path d="M9 8.5 C12 10.5 13.5 13.5 13 17"/>
              <path d="M9.5 14 C12.5 16 13.5 19 12.5 22.5"/>
            </svg>
            <span>{{ award_parts.last | strip }}</span>
            <svg class="tamarinse-hero__laurel tamarinse-hero__laurel--right" viewBox="0 0 22 30" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" aria-hidden="true">
              <path d="M19 29 C11.5 25 8 17 9.5 2.5"/>
              <path d="M9.5 3 C6 4.5 4 7.5 4 11"/>
              <path d="M9 8.5 C5.5 10 3.5 13 3.5 16.5"/>
              <path d="M9.5 14 C6.5 15.5 5 18.5 5.5 22"/>
              <path d="M11 19.5 C8.5 21 7.5 24 8.5 27"/>
              <path d="M9.5 3 C12.5 5 14 8 13.5 11.5"/>
              <path d="M9 8.5 C12 10.5 13.5 13.5 13 17"/>
              <path d="M9.5 14 C12.5 16 13.5 19 12.5 22.5"/>
            </svg>
          </span>
        </p>
      {%- endif -%}
      {%- comment -%}
        Lead statement (client 2026-07-21). Sits directly above the headline
        so the two read as one lockup under the bottle. Deliberately a <p>,
        not a heading: "Daily Defense Against Microplastics™" stays the H1 —
        it's the phrase the page needs to rank for, and demoting it to make
        room for a tagline would cost that.
      {%- endcomment -%}
      {%- if section.settings.lead_line != blank -%}
        <p class="tamarinse-hero__lead">{{ section.settings.lead_line | replace: '™', '<sup class="tamarinse-hero__tm">™</sup>' }}</p>
      {%- endif -%}
      <h1 class="tamarinse-hero__headline">{{ section.settings.headline | replace: '™', '<sup class="tamarinse-hero__tm">™</sup>' }}</h1>
      <p class="tamarinse-hero__subheadline">{{ section.settings.subheadline }}</p>
      <div class="tamarinse-hero__actions">
        {%- if section.settings.primary_cta_label != blank -%}
          {%- capture tamarinse_shop_url -%}{% render 'tamarinse-shop-url' %}{%- endcapture -%}
          <a
            class="t-btn t-btn--pill"
            href="{{ section.settings.primary_cta_link | default: tamarinse_shop_url }}"
          >
            {%- comment -%} Open-cap art; fades in over the seated cap on hover {%- endcomment -%}
            <span class="t-btn__cap" aria-hidden="true"></span>
            {{- section.settings.primary_cta_label -}}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_label != blank -%}
          <a
            class="t-btn t-btn--ghost"
            href="{{ section.settings.secondary_cta_link | default: '#how-tamarinse-works' }}"
          >
            {{- section.settings.secondary_cta_label -}}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_badges -%}
        <div class="tamarinse-hero__badges">
          {%- if section.settings.badge_1 != blank
            or section.settings.badge_2 != blank
            or section.settings.badge_3 != blank
          -%}
            {%- assign badges = 'badge_1,badge_2,badge_3' | split: ',' -%}
            {%- for key in badges -%}
              {%- if section.settings[key] != blank -%}
                <span class="tamarinse-hero__badge-cell">
                  {{
                    section.settings[key]
                    | image_url: width: 160
                    | image_tag: class: 'tamarinse-hero__badge', loading: 'lazy', alt: section.settings[key].alt
                  }}
                </span>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Bundled certification badges (tamarinse.com) {%- endcomment -%}
            <span class="tamarinse-hero__badge-cell"><img src="{{ 'tamarinse-badge-usda.webp' | asset_url }}" class="tamarinse-hero__badge" alt="USDA Organic" width="400" height="400" loading="lazy"></span>
            <span class="tamarinse-hero__badge-cell"><img src="{{ 'tamarinse-badge-usa.webp' | asset_url }}" class="tamarinse-hero__badge" alt="Made in USA" width="400" height="400" loading="lazy"></span>
            <span class="tamarinse-hero__badge-cell"><img src="{{ 'tamarinse-badge-gmp.webp' | asset_url }}" class="tamarinse-hero__badge" alt="Good Manufacturing Practice certified" width="400" height="400" loading="lazy"></span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%}
      Scroll-scrubbed 360° turntable — frames rendered from the product
      video with the studio backdrop keyed out. Grab-to-rotate included.
      data-scroll-root points at the tall section wrapper: progress through
      its pinned range drives exactly one full rotation.
    {%- endcomment -%}
    <tamarinse-bottle-sequence
      class="tamarinse-hero__scene"
      data-scroll-root=".tamarinse-hero"
      data-frame-count="120"
      data-frames-desktop="{{ 'tamarinse-bottle-frame-000.webp' | asset_url }}"
      data-frames-mobile="{{ 'tamarinse-bottle-frame-m-000.webp' | asset_url }}"
      aria-hidden="true"
    >
      <canvas class="tamarinse-hero__canvas"></canvas>
      <div class="tamarinse-hero__fallback">
        {%- if section.settings.fallback_image != blank -%}
          {{
            section.settings.fallback_image
            | image_url: width: 1200
            | image_tag:
              widths: '600, 900, 1200',
              sizes: '(min-width: 750px) 44vw, 78vw',
              class: 'tamarinse-hero__fallback-image',
              alt: section.settings.fallback_image.alt
          }}
        {%- else -%}
          {%- comment -%}
            First frame of the turntable sequence — identical to what the
            canvas paints, so the swap to the live scrubber is seamless.
          {%- endcomment -%}
          <picture>
            <source
              media="(max-width: 749px)"
              srcset="{{ 'tamarinse-bottle-frame-m-000.webp' | asset_url }}"
              width="365"
              height="704"
            >
            <img
              src="{{ 'tamarinse-bottle-frame-000.webp' | asset_url }}"
              class="tamarinse-hero__fallback-image"
              alt="Tamarinse™ bottle"
              width="597"
              height="1152"
            >
          </picture>
        {%- endif -%}
      </div>
    </tamarinse-bottle-sequence>
    </div>
  </div>
</section>

<script src="{{ 'tamarinse-bottle-sequence.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .tamarinse-hero {
    display: block;
    background: var(--t-bg);
    color: var(--t-text-hi);
    /* Scroll-jack track: the extra height is the scrub distance the visitor
       travels while the sticky stage below holds the hero on screen for one
       full bottle rotation. */
    height: calc(100svh + var(--hero-scroll-length, 160vh));
  }

  .tamarinse-hero__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: center;
    /* Top pad clears the overlaying header while pinned; bottom pad clears
       the floating buy bar and the iOS home indicator. */
    padding: calc(var(--header-height, 64px) + var(--t-space-2xs)) var(--t-space-md)
      calc(var(--t-space-md) + env(safe-area-inset-bottom, 0px));
  }

  /* Reduced motion (set by the sequence element): no pin, no dead scroll —
     back to a single confident screen. */
  .tamarinse-hero[data-static] {
    height: auto;
  }

  .tamarinse-hero[data-static] .tamarinse-hero__sticky {
    position: static;
    height: auto;
    min-height: calc(100svh - var(--header-height, 64px));
    overflow: visible;
  }

  .tamarinse-hero__inner {
    width: 100%;
    height: 100%;
    max-width: var(--t-content-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    justify-content: center;
    /* min-height:0 lets the bottle shrink instead of overflowing the pinned
       stage — without it the column stays at its natural height and the
       centered overflow gets clipped at BOTH ends (bottle cap off the top,
       secondary CTA off the bottom) on short screens. */
    min-height: 0;
    gap: clamp(var(--t-space-sm), 3svh, var(--t-space-lg));
  }

  .tamarinse-hero__content {
    /* Copy keeps its natural height; the bottle absorbs the slack */
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: var(--t-copy-max);
    gap: clamp(var(--t-space-2xs), 1.2svh, var(--t-space-sm));
    animation: tamarinse-hero-rise 900ms var(--t-ease-out) both;
  }

  /* Award lockup — the one place the accent green appears in the hero besides
     the CTA. Set like an engraving: a quiet lead line over a laurel-flanked
     prize line, no chip fill, so it reads as an honor rather than a sticker. */
  .tamarinse-hero__award {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
    margin: 0 0 var(--t-space-2xs);
  }

  .tamarinse-hero__award-lead {
    display: block;
    width: 100%;
    color: var(--t-text-low);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: var(--t-weight-medium);
    text-align: center;
    /* Cancel trailing letter-spacing so the line optically centers */
    margin-inline-end: -0.22em;
  }

  .tamarinse-hero__award-main {
    display: inline-flex;
    align-items: center;
    gap: 0.625em;
    color: var(--t-accent-deep);
    font-family: var(--t-font-heading);
    font-size: 0.9375rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    font-weight: var(--t-weight-semibold);
    white-space: nowrap;
  }

  .tamarinse-hero__laurel {
    width: auto;
    height: 1.7em;
    flex: none;
    opacity: 0.8;
  }

  .tamarinse-hero__laurel--right {
    transform: scaleX(-1);
  }

  /* Lead statement: same serif as the headline so they read as one lockup,
     but lighter and smaller so the H1 keeps the visual hierarchy. */
  .tamarinse-hero__lead {
    font-family: var(--t-font-heading);
    font-size: clamp(1.125rem, 0.85rem + 1.1vw, 1.5rem);
    line-height: 1.3;
    font-weight: var(--t-weight-body);
    font-style: italic;
    color: var(--t-text-mid);
    margin: 0;
    max-width: 26ch;
    text-wrap: balance;
  }

  .tamarinse-hero__headline {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-display);
    line-height: var(--t-leading-tight);
    font-weight: var(--t-weight-display);
    margin: 0;
    text-wrap: balance;
  }

  .tamarinse-hero__tm {
    font-size: 0.35em;
    vertical-align: super;
    line-height: 0;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .tamarinse-hero__subheadline {
    font-family: var(--t-font-body);
    font-size: var(--t-type-small);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    letter-spacing: 0.015em;
    margin: 0;
    max-width: 30rem;
    text-wrap: pretty;
  }

  .tamarinse-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--t-space-xs);
    margin-block-start: clamp(var(--t-space-2xs), 1.5svh, var(--t-space-sm));
  }

  .tamarinse-hero__badges {
    display: flex;
    align-items: center;
    gap: var(--t-space-sm);
    margin-block-start: clamp(var(--t-space-xs), 2svh, var(--t-space-md));
  }

  /*
    Stacked (mobile) layout: the bottle is the flexible member of the column,
    so it already takes every pixel the copy leaves — raising its height cap
    does nothing once the column is full. The only way to grow it is to hand
    it space back, so the copy runs tighter here than the shared tokens:
    a smaller display size, a compact award lockup, and slimmer gaps. That
    buys the bottle roughly 70–90px of height on a typical phone.
  */
  @media screen and (max-width: 749px) {
    .tamarinse-hero__headline {
      font-size: clamp(2rem, 0.4rem + 6.6vw, 2.875rem);
    }

    .tamarinse-hero__subheadline {
      font-size: 0.8125rem;
      line-height: 1.5;
    }

    /* Trimmed like the rest of the stacked copy — the pinned viewport is a
       fixed budget and every rem here comes off the bottle. The measure cap
       is lifted too so the line fits on ONE row on a typical phone; at 26ch
       it wrapped to two and cost the bottle another ~20px. */
    .tamarinse-hero__lead {
      font-size: 0.9375rem;
      max-width: 100%;
    }

    .tamarinse-hero__award {
      gap: 0.15rem;
      margin-block-end: 0;
    }

    .tamarinse-hero__award-lead {
      font-size: 0.625rem;
      letter-spacing: 0.18em;
    }

    .tamarinse-hero__award-main {
      font-size: 0.8125rem;
    }

    .tamarinse-hero__laurel {
      height: 1.45em;
    }

    .tamarinse-hero__actions {
      margin-block-start: var(--t-space-2xs);
    }

    /* Tighter than the shared clamp — every rem here goes to the bottle */
    .tamarinse-hero__inner {
      gap: clamp(0.5rem, 2svh, 1.25rem);
    }

    .tamarinse-hero__content {
      gap: clamp(0.25rem, 0.9svh, 0.625rem);
    }

    .tamarinse-hero__sticky {
      padding-inline: var(--t-space-sm);
      padding-block-start: calc(var(--header-height, 64px) + 2px);
    }
  }

  /* Short phones: reclaim height so the bottle keeps real presence and the
     CTAs stay clear of the fold. Badges shrink first, then step aside —
     they repeat immediately below in the Quality Standards row. */
  @media screen and (max-width: 989px) and (max-height: 760px) {
    .tamarinse-hero__badge {
      width: 36px;
      height: 36px;
    }

    .tamarinse-hero__badge-cell + .tamarinse-hero__badge-cell {
      padding-inline-start: var(--t-space-xs);
    }
  }

  @media screen and (max-width: 989px) and (max-height: 670px) {
    .tamarinse-hero__badges {
      display: none;
    }

    /* Trim the display type too, so the freed height goes to the bottle
       rather than to three tall headline lines */
    .tamarinse-hero__headline {
      font-size: clamp(1.875rem, 1rem + 5vw, 2.625rem);
    }
  }

  .tamarinse-hero__badge-cell {
    display: inline-flex;
  }

  .tamarinse-hero__badge {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 50%;
  }

  /* Hairline dividers between certifications, echoing the brand poster's
     badge strip */
  .tamarinse-hero__badge-cell + .tamarinse-hero__badge-cell {
    padding-inline-start: var(--t-space-sm);
    border-inline-start: 1px solid var(--t-border);
  }

  .tamarinse-hero__scene {
    position: relative;
    display: block;
    /* Height-driven box matching the turntable frames' aspect (597:1152)
       so the bottle fills the canvas edge to edge. It's the flexible member
       of the pinned column: it takes the space the copy leaves and shrinks
       on short screens rather than being clipped by the stage. The canvas
       paints contain-fit, so a shorter box just renders a smaller bottle. */
    flex: 1 1 auto;
    min-height: 0;
    height: min(68svh, 640px);
    max-height: 100%;
    aspect-ratio: 597 / 1152;
    animation: tamarinse-hero-fade 1100ms var(--t-ease-out) 150ms both;
  }

  .tamarinse-hero__scene canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    /* Grab-to-rotate: horizontal drags spin the jar; pan-y keeps vertical
       touch swipes scrolling the page instead of being swallowed. */
    touch-action: pan-y;
    cursor: grab;
    -webkit-user-select: none;
    user-select: none;
  }

  .tamarinse-hero__scene[data-grabbing] canvas {
    cursor: grabbing;
  }

  /* Fallback bottle photo: shown until the turntable's first frame paints */
  .tamarinse-hero__fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity var(--t-dur-slow) var(--t-ease-out);
  }

  .tamarinse-hero__scene[data-active] .tamarinse-hero__fallback {
    opacity: 0;
  }

  .tamarinse-hero__fallback picture {
    display: contents;
  }

  .tamarinse-hero__fallback-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  /* Merchant-picked photos may have a white studio backdrop — melt it into
     the page. The bundled sequence frame is transparent and skips this. */
  .tamarinse-hero__fallback-image[src*='.jpg'],
  .tamarinse-hero__fallback-image[src$='.jpeg'],
  .tamarinse-hero__fallback-image[src*='.webp'] {
    mix-blend-mode: multiply;
  }

  @keyframes tamarinse-hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes tamarinse-hero-fade {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tamarinse-hero__content,
    .tamarinse-hero__scene {
      animation: none;
    }
  }

  @media screen and (min-width: 990px) {
    /* Center the copy + bottle as one composition with a fixed gap instead
       of space-between, which pinned the bottle to the container's right
       edge and left a dead zone in the middle. */
    .tamarinse-hero__inner {
      flex-direction: row;
      justify-content: center;
      gap: clamp(var(--t-space-xl), 6vw, 6.5rem);
    }

    .tamarinse-hero__content {
      align-items: flex-start;
      text-align: left;
      flex: 0 1 34rem;
      min-width: 0;
    }

    .tamarinse-hero__award {
      align-items: flex-start;
    }

    /* The split layout leaves the copy ~50% of the row minus the bottle
       column, so the display token's 5.5rem max never fits — "Microplastics™"
       would overflow into the bottle. Cap the size to the column instead. */
    .tamarinse-hero__headline {
      font-size: clamp(2.75rem, 0.5rem + 5vw, 4.4rem);
    }

    .tamarinse-hero__actions {
      justify-content: flex-start;
    }

    .tamarinse-hero__scene {
      flex: 0 0 auto;
      height: min(74svh, 800px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse Hero",
  "tag": "section",
  "class": "tamarinse-hero-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "lead_line",
      "label": "Statement above headline",
      "default": "Your body wasn't designed for plastic.",
      "info": "Sits directly under the bottle, above the headline. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Daily Defense Against Microplastics™"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Physician Formulated • USDA Organic • Clinically Studied Ingredients. Made in the USA"
    },
    {
      "type": "text",
      "id": "award_text",
      "label": "Award line",
      "default": "Award-Winning Ingredients — 2026 Earth Prize Winner",
      "info": "Shown as a green chip above the headline. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary button label",
      "default": "Shop Tamarinse™"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "How It Works"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show certification badges",
      "default": true,
      "info": "USDA Organic, Made in USA, and GMP badges are bundled; pick images below to replace them."
    },
    {
      "type": "image_picker",
      "id": "badge_1",
      "label": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_2",
      "label": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_3",
      "label": "Badge 3"
    },
    {
      "type": "header",
      "content": "Bottle"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Static bottle image",
      "info": "Shown while the 3D bottle loads, and instead of it on low-end devices or when reduced motion is enabled."
    },
    {
