{% comment %}
  Tamarinse Hero — static, confident opener (client rev. 2026-07-16).
  No scroll-pinning or scrubbing: one full-viewport screen, copy beside the
  slowly rotating 3D bottle, with a single staggered entrance animation on
  load. All copy is editable; defaults come from CONTENT.md.
{% endcomment %}

<section
  class="tamarinse-hero"
  id="TamarinseHero-{{ section.id }}"
  style="--t-bottle-period: {{ section.settings.rotation_seconds }}s;"
>
  <div class="tamarinse-hero__inner">
    <div class="tamarinse-hero__content">
      <h1 class="tamarinse-hero__headline">{{ section.settings.headline }}</h1>
      <p class="tamarinse-hero__subheadline">{{ section.settings.subheadline }}</p>
      <div class="tamarinse-hero__actions">
        {%- if section.settings.primary_cta_label != blank -%}
          <a
            class="t-btn t-btn--accent"
            href="{{ section.settings.primary_cta_link | default: routes.all_products_collection_url }}"
          >
            {{- section.settings.primary_cta_label -}}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_label != blank -%}
          <a
            class="t-btn t-btn--ghost"
            href="{{ section.settings.secondary_cta_link | default: '#how-tamarinse-works' }}"
          >
            {{- section.settings.secondary_cta_label -}}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_badges -%}
        <div class="tamarinse-hero__badges">
          {%- if section.settings.badge_1 != blank
            or section.settings.badge_2 != blank
            or section.settings.badge_3 != blank
          -%}
            {%- assign badges = 'badge_1,badge_2,badge_3' | split: ',' -%}
            {%- for key in badges -%}
              {%- if section.settings[key] != blank -%}
                {{
                  section.settings[key]
                  | image_url: width: 160
                  | image_tag: class: 'tamarinse-hero__badge', loading: 'lazy', alt: section.settings[key].alt
                }}
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Bundled certification badges (tamarinse.com) {%- endcomment -%}
            <img src="{{ 'tamarinse-badge-usda.png' | asset_url }}" class="tamarinse-hero__badge" alt="USDA Organic" width="400" height="400" loading="lazy">
            <img src="{{ 'tamarinse-badge-usa.png' | asset_url }}" class="tamarinse-hero__badge" alt="Made in USA" width="400" height="400" loading="lazy">
            <img src="{{ 'tamarinse-badge-gmp.png' | asset_url }}" class="tamarinse-hero__badge" alt="Good Manufacturing Practice certified" width="400" height="400" loading="lazy">
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <tamarinse-bottle-scene
      class="tamarinse-hero__scene"
      data-environment="{{ 'brown_photostudio_02_1k.exr' | asset_url }}"
      aria-hidden="true"
    >
      <div class="tamarinse-hero__fallback">
        {%- if section.settings.fallback_image != blank -%}
          {{
            section.settings.fallback_image
            | image_url: width: 1200
            | image_tag:
              widths: '600, 900, 1200',
              sizes: '(min-width: 750px) 44vw, 78vw',
              class: 'tamarinse-hero__fallback-image',
              alt: section.settings.fallback_image.alt
          }}
        {%- else -%}
          {%- comment -%} Bundled product photo (tamarinse.com) until a merchant image is picked {%- endcomment -%}
          <img
            src="{{ 'tamarinse-bottle-photo-hires.jpg' | asset_url }}"
            class="tamarinse-hero__fallback-image"
            alt="Tamarinse™ bottle"
            width="1290"
            height="1632"
          >
        {%- endif -%}
      </div>
    </tamarinse-bottle-scene>
  </div>
</section>

<script src="{{ 'tamarinse-bottle-scene.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .tamarinse-hero {
    display: block;
    background: var(--t-bg);
    color: var(--t-text-hi);
    min-height: calc(100svh - var(--header-height, 64px));
    padding: var(--t-space-lg) var(--t-space-md) var(--t-space-xl);
    display: flex;
    align-items: center;
  }

  .tamarinse-hero__inner {
    width: 100%;
    max-width: var(--t-content-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: var(--t-space-lg);
  }

  .tamarinse-hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: var(--t-copy-max);
    gap: var(--t-space-sm);
    animation: tamarinse-hero-rise 900ms var(--t-ease-out) both;
  }

  .tamarinse-hero__headline {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-display);
    line-height: var(--t-leading-tight);
    font-weight: 400;
    margin: 0;
    text-wrap: balance;
  }

  .tamarinse-hero__subheadline {
    font-family: var(--t-font-body);
    font-size: var(--t-type-small);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    letter-spacing: 0.06em;
    margin: 0;
    max-width: 34rem;
  }

  .tamarinse-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--t-space-xs);
    margin-block-start: var(--t-space-sm);
  }

  .tamarinse-hero__badges {
    display: flex;
    align-items: center;
    gap: var(--t-space-md);
    margin-block-start: var(--t-space-md);
  }

  .tamarinse-hero__badge {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .tamarinse-hero__scene {
    position: relative;
    display: block;
    width: min(78vw, 340px);
    aspect-ratio: 4 / 5;
    animation: tamarinse-hero-fade 1100ms var(--t-ease-out) 150ms both;
  }

  .tamarinse-hero__scene canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Fallback bottle: shown until WebGL activates, and permanently on
     low-tier devices */
  .tamarinse-hero__fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity var(--t-dur-slow) var(--t-ease-out);
  }

  .tamarinse-hero__scene[data-webgl-active] .tamarinse-hero__fallback {
    opacity: 0;
  }

  .tamarinse-hero__fallback-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply; /* melts the photo's white backdrop into the page */
  }

  @keyframes tamarinse-hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes tamarinse-hero-fade {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tamarinse-hero__content,
    .tamarinse-hero__scene {
      animation: none;
    }
  }

  @media screen and (min-width: 990px) {
    .tamarinse-hero__inner {
      flex-direction: row;
      justify-content: space-between;
      gap: var(--t-space-xl);
    }

    .tamarinse-hero__content {
      align-items: flex-start;
      text-align: left;
      flex: 1 1 50%;
    }

    .tamarinse-hero__actions {
      justify-content: flex-start;
    }

    .tamarinse-hero__scene {
      flex: 0 0 auto;
      width: min(38vw, 460px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse Hero",
  "tag": "section",
  "class": "tamarinse-hero-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Daily Defense Against Microplastics™"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Physician Formulated • USDA Organic • Clinically Studied Ingredients. Made in the USA"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary button label",
      "default": "Shop Tamarinse™"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "How It Works"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show certification badges",
      "default": true,
      "info": "USDA Organic, Made in USA, and GMP badges are bundled; pick images below to replace them."
    },
    {
      "type": "image_picker",
      "id": "badge_1",
      "label": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_2",
      "label": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_3",
      "label": "Badge 3"
    },
    {
      "type": "header",
      "content": "Bottle"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Static bottle image",
      "info": "Shown while the 3D bottle loads, and instead of it on low-end devices or when reduced motion is enabled."
    },
    {
      "type": "range",
      "id": "rotation_seconds",
      "label": "Rotation duration",
      "min": 20,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Tamarinse Hero",
      "category": "Tamarinse"
    }
  ]
}
{% endschema %}
