{% comment %}
  The Problem (MASTER_PROMPT #4) — full-screen immersive photography, one
  statistic per screen, minimal copy. Block-based: statistic + source citation
  + art-directed desktop/mobile images (CONTENT.md: stats need real cited
  sources before launch — source field is required rendering, not optional
  decoration).
{% endcomment %}

<section class="tamarinse-problem" id="TamarinseProblem-{{ section.id }}">
  {%- if section.settings.title != blank -%}
    <h2 class="visually-hidden">{{ section.settings.title }}</h2>
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- liquid
      # A merchant-picked image wins; otherwise fall back to a bundled theme
      # asset (image_picker settings cannot reference theme assets directly).
      assign has_photo = false
      if block.settings.image != blank or block.settings.asset_fallback != blank
        assign has_photo = true
      endif
    -%}
    <div class="tamarinse-problem__panel{% if has_photo %} tamarinse-problem__panel--photo{% endif %}" {{ block.shopify_attributes }}>
      <div class="tamarinse-problem__media" aria-hidden="{% if has_photo %}false{% else %}true{% endif %}">
        {%- if block.settings.image != blank -%}
          <picture>
            {%- if block.settings.image_mobile != blank -%}
              <source
                media="(max-width: 749px)"
                srcset="
                  {{ block.settings.image_mobile | image_url: width: 500 }} 500w,
                  {{ block.settings.image_mobile | image_url: width: 800 }} 800w,
                  {{ block.settings.image_mobile | image_url: width: 1200 }} 1200w
                "
                sizes="100vw"
                width="{{ block.settings.image_mobile.width }}"
                height="{{ block.settings.image_mobile.height }}"
              >
            {%- endif -%}
            {{
              block.settings.image
              | image_url: width: 2560
              | image_tag:
                widths: '832, 1200, 1600, 1920, 2560',
                sizes: '100vw',
                class: 'tamarinse-problem__image',
                loading: 'lazy',
                alt: block.settings.image.alt
            }}
          </picture>
        {%- elsif block.settings.asset_fallback != blank -%}
          <img
            src="{{ block.settings.asset_fallback | asset_url }}"
            class="tamarinse-problem__image"
            alt=""
            width="1820"
            height="1024"
            loading="lazy"
          >
        {%- endif -%}
        <span class="tamarinse-problem__scrim"></span>
      </div>
      <figure class="tamarinse-problem__figure">
        <blockquote class="tamarinse-problem__stat">{{ block.settings.statistic }}</blockquote>
        {%- if block.settings.source != blank -%}
          <figcaption class="tamarinse-problem__source">{{ block.settings.source }}</figcaption>
        {%- endif -%}
      </figure>
    </div>
  {%- endfor -%}
</section>

{% stylesheet %}
  .tamarinse-problem {
    display: block;
    background: var(--t-bg);
    color: var(--t-text-hi);
  }

  .tamarinse-problem__panel {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: var(--t-space-xl) var(--t-space-md);
  }

  .tamarinse-problem__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--t-surface);
  }

  .tamarinse-problem__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tamarinse-problem__scrim {
    position: absolute;
    inset: 0;
  }

  /* Photo panels: white copy over a dark scrim. Placeholder panels stay light. */
  .tamarinse-problem__panel--photo .tamarinse-problem__scrim {
    background: var(--t-photo-scrim);
  }

  .tamarinse-problem__panel--photo .tamarinse-problem__stat {
    color: var(--t-photo-text);
  }

  .tamarinse-problem__panel--photo .tamarinse-problem__source {
    color: var(--t-photo-text-mid);
  }

  .tamarinse-problem__figure {
    position: relative;
    margin: 0;
    max-width: var(--t-content-max);
    margin-inline: auto;
    width: 100%;
  }

  .tamarinse-problem__stat {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    max-width: 22ch;
    margin: 0 0 var(--t-space-sm);
    text-wrap: balance;
  }

  .tamarinse-problem__source {
    font-size: var(--t-type-small);
    color: var(--t-text-mid);
    letter-spacing: 0.04em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse The Problem",
  "tag": "section",
  "class": "tamarinse-problem-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Accessible section title",
      "default": "The problem: everyday microplastics exposure"
    },
    {
      "type": "paragraph",
      "content": "Statistics must be real and cited before launch (see LAUNCH_CHECKLIST.md). The defaults below are placeholders and clearly marked."
    }
  ],
  "blocks": [
    {
      "type": "statistic",
      "name": "Statistic",
      "settings": [
        {
          "type": "textarea",
          "id": "statistic",
          "label": "Statistic"
        },
        {
          "type": "text",
          "id": "source",
          "label": "Source citation",
          "info": "Required before launch — do not publish uncited figures."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (landscape, desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (portrait crop, mobile)"
        },
        {
          "type": "text",
          "id": "asset_fallback",
          "label": "Bundled photo filename",
          "info": "Theme asset used until a real image is picked above (e.g. tamarinse-photo-containers.jpg)."
        }
      ]
    }
  ],
  "max_blocks": 7,
  "presets": [
    {
      "name": "Tamarinse The Problem",
      "category": "Tamarinse",
      "blocks": [
        {
          "type": "statistic",
          "settings": {
            "statistic": "You could be ingesting up to a credit card's worth of plastic every week.",
            "source": "WWF × University of Newcastle analysis, 2019 — verify before launch",
            "asset_fallback": "tamarinse-photo-containers.jpg"
          }
        },
        {
          "type": "statistic",
          "settings": {
            "statistic": "Microplastics were detected in the blood of nearly 8 in 10 people tested.",
            "source": "Environment International, 2022 — verify before launch",
            "asset_fallback": "tamarinse-photo-tap-water.jpg"
          }
        },
        {
          "type": "statistic",
          "settings": {
            "statistic": "A single liter of bottled water can contain around 240,000 plastic particles.",
            "source": "Proceedings of the National Academy of Sciences, 2024 — verify before launch",
            "asset_fallback": "tamarinse-photo-bottled-water.jpg"
          }
        }
      ]
    }
  ]
}
{% endschema %}
