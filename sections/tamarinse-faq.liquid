{% comment %}
  FAQ (MASTER_PROMPT #14) — reuse existing content (populate blocks from
  current Tamarinse.com). Native details/summary accordion + FAQPage
  structured data (BUILD_GUIDE section 7, SEO requirements).
{% endcomment %}

<section class="tamarinse-faq t-on-light" id="TamarinseFaq-{{ section.id }}">
  <div class="tamarinse-faq__inner">
    {%- comment -%}
      Two-column spread on desktop: the header column stays pinned while the
      accordion scrolls, so the section fills its width instead of floating
      as a narrow strip in empty tint.
    {%- endcomment -%}
    <header class="tamarinse-faq__header">
      <p class="t-eyebrow t-eyebrow--ruled tamarinse-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tamarinse-faq__title">{{ section.settings.title }}</h2>
      {%- if section.settings.support_text != blank -%}
        <p class="tamarinse-faq__support">
          {{ section.settings.support_text }}
          {%- if section.settings.support_link_label != blank %}
            <a class="tamarinse-faq__support-link" href="{{ section.settings.support_link | default: '/pages/contact' }}">{{ section.settings.support_link_label }}</a>
          {%- endif -%}
        </p>
      {%- endif -%}
    </header>

    <div class="tamarinse-faq__list">
      {%- for block in section.blocks -%}
        <details class="tamarinse-faq__item" {{ block.shopify_attributes }}>
          <summary class="tamarinse-faq__question">
            <span class="tamarinse-faq__index" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <span class="tamarinse-faq__question-text">{{ block.settings.question }}</span>
            <span class="tamarinse-faq__marker" aria-hidden="true"></span>
          </summary>
          <div class="tamarinse-faq__answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
</section>

{% stylesheet %}
  .tamarinse-faq {
    display: block;
    /* Cream, not tint: reviews (before) and closing (after) are both sand
       panels, so the FAQ separates them instead of merging into one field */
    background: var(--t-bg);
    color: var(--t-text-hi);
    padding: var(--t-space-section) var(--t-space-md);
  }

  .tamarinse-faq__inner {
    max-width: var(--t-content-max);
    margin-inline: auto;
  }

  .tamarinse-faq__header {
    margin-block-end: var(--t-space-xl);
  }

  .tamarinse-faq__eyebrow {
    color: var(--t-text-low);
    margin: 0 0 var(--t-space-sm);
  }

  .tamarinse-faq__title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    margin: 0;
    max-width: 12ch;
    text-wrap: balance;
  }

  .tamarinse-faq__support {
    font-size: var(--t-type-body);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    max-width: 26rem;
    margin: var(--t-space-md) 0 0;
    text-wrap: pretty;
  }

  .tamarinse-faq__support-link {
    color: var(--t-accent-deep);
    font-weight: var(--t-weight-semibold);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .tamarinse-faq__item {
    border-block-start: 1px solid var(--t-border);
    interpolate-size: allow-keywords;
  }

  .tamarinse-faq__item:last-child {
    border-block-end: 1px solid var(--t-border);
  }

  /* Question row: numbered index in the brand serif, question set as a small
     serif heading, circled marker on the right */
  .tamarinse-faq__question {
    display: flex;
    align-items: baseline;
    gap: var(--t-space-sm);
    min-height: var(--t-touch-target);
    padding: var(--t-space-md) 0;
    cursor: pointer;
    list-style: none;
  }

  .tamarinse-faq__question::-webkit-details-marker {
    display: none;
  }

  .tamarinse-faq__index {
    flex: none;
    width: 2rem;
    font-family: var(--t-font-heading);
    font-size: var(--t-type-eyebrow);
    font-weight: var(--t-weight-medium);
    color: var(--t-text-low);
    letter-spacing: 0.06em;
    transition: color var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-faq__question-text {
    flex: 1;
    font-family: var(--t-font-heading);
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
    font-weight: var(--t-weight-subheading);
    line-height: var(--t-leading-heading);
    transition: color var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-faq__question:hover .tamarinse-faq__question-text {
    color: var(--t-accent-deep);
  }

  .tamarinse-faq__item[open] .tamarinse-faq__index {
    color: var(--t-accent);
  }

  /* Circled plus/minus marker */
  .tamarinse-faq__marker {
    flex: none;
    align-self: center;
    position: relative;
    width: 28px;
    height: 28px;
    border: 1px solid var(--t-border);
    border-radius: 50%;
    transition:
      border-color var(--t-dur-fast) var(--t-ease-out),
      background-color var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-faq__question:hover .tamarinse-faq__marker {
    border-color: var(--t-text-mid);
  }

  .tamarinse-faq__marker::before,
  .tamarinse-faq__marker::after {
    content: '';
    position: absolute;
    inset: 50% 8px auto;
    height: 1.5px;
    background: var(--t-text-mid);
    transition:
      transform var(--t-dur-fast) var(--t-ease-out),
      background-color var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-faq__marker::after {
    transform: rotate(90deg);
  }

  .tamarinse-faq__item[open] .tamarinse-faq__marker {
    background: var(--t-ink);
    border-color: var(--t-ink);
  }

  .tamarinse-faq__item[open] .tamarinse-faq__marker::before,
  .tamarinse-faq__item[open] .tamarinse-faq__marker::after {
    background: var(--t-bg);
  }

  .tamarinse-faq__item[open] .tamarinse-faq__marker::after {
    transform: rotate(0deg);
  }

  /* Animated expand/collapse (native details content) */
  .tamarinse-faq__item::details-content {
    block-size: 0;
    overflow: clip;
    opacity: 0;
    transition:
      block-size var(--t-dur-med) var(--t-ease-out),
      opacity var(--t-dur-med) var(--t-ease-out),
      content-visibility var(--t-dur-med) allow-discrete;
  }

  .tamarinse-faq__item[open]::details-content {
    block-size: auto;
    opacity: 1;

    @starting-style {
      block-size: 0;
      opacity: 0;
    }
  }

  /* Answer aligns under the question text, past the index column */
  .tamarinse-faq__answer {
    padding: 0 0 var(--t-space-md) calc(2rem + var(--t-space-sm));
    font-size: var(--t-type-body);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    max-width: 56ch;
    text-wrap: pretty;
  }

  /* Two-column spread: pinned header beside the accordion, so the section
     holds its width instead of floating as a narrow centered strip */
  @media screen and (min-width: 990px) {
    .tamarinse-faq__inner {
      display: grid;
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--t-space-xl);
      align-items: start;
    }

    .tamarinse-faq__header {
      position: sticky;
      top: calc(var(--header-height, 64px) + var(--t-space-lg));
      margin-block-end: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tamarinse-faq__index,
    .tamarinse-faq__question-text,
    .tamarinse-faq__marker,
    .tamarinse-faq__marker::before,
    .tamarinse-faq__marker::after,
    .tamarinse-faq__item::details-content {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse FAQ",
  "tag": "section",
  "class": "tamarinse-faq-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Questions, answered."
    },
    {
      "type": "text",
      "id": "support_text",
      "label": "Support line",
      "default": "Can't find what you're looking for?",
      "info": "Shown under the title. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "support_link_label",
      "label": "Support link label",
      "default": "Get in touch"
    },
    {
      "type": "url",
      "id": "support_link",
      "label": "Support link"
    },
    {
      "type": "paragraph",
      "content": "Populate questions/answers from the existing Tamarinse.com FAQ (CONTENT.md: reuse existing content)."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tamarinse FAQ",
      "category": "Tamarinse",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "What is Tamarinse?",
            "answer": "<p>Tamarinse is the first premium supplement built around tamarind seed extract for daily environmental defense. Our formula combines five plant-based ingredients designed to support your body's natural detoxification pathways and digestive elimination. 60 capsules per bottle. 30-day supply.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I take it?",
            "answer": "<p>Take 2 capsules daily with water, preferably with a meal. Consistency is key — Tamarinse is designed for daily long-term use, not a one-time cleanse.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is Tamarinse safe to take every day?",
            "answer": "<p>Yes. Every ingredient is USDA Organic, third-party tested, and manufactured in a cGMP certified, FDA registered facility in the USA. The activated charcoal is micro-dosed at 100mg specifically for safe daily use.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Why tamarind?",
            "answer": "<p>Tamarind seed extract contains natural polysaccharides that are currently being studied by researchers worldwide for their ability to bind to microplastic particles in digestive environments. It is the most promising plant-based compound in the category — and the reason we built the entire brand around it.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Why is the bottle made of glass?",
            "answer": "<p>We believe putting a microplastic defense supplement in a plastic bottle defeats the purpose. Our glass bottle is better for the product, better for the planet, and aligned with everything Tamarinse stands for.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Orders ship within 1-2 business days and typically arrive within 5-7 business days depending on your location.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
