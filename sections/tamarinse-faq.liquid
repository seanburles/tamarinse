{% comment %}
  FAQ (MASTER_PROMPT #14) — reuse existing content (populate blocks from
  current Tamarinse.com). Native details/summary accordion + FAQPage
  structured data (BUILD_GUIDE section 7, SEO requirements).
{% endcomment %}

<section class="tamarinse-faq t-on-light" id="TamarinseFaq-{{ section.id }}">
  <div class="tamarinse-faq__inner">
    <header class="tamarinse-faq__header">
      <p class="t-eyebrow tamarinse-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tamarinse-faq__title">{{ section.settings.title }}</h2>
    </header>

    <div class="tamarinse-faq__list">
      {%- for block in section.blocks -%}
        <details class="tamarinse-faq__item" {{ block.shopify_attributes }}>
          <summary class="tamarinse-faq__question">
            {{ block.settings.question }}
            <span class="tamarinse-faq__marker" aria-hidden="true"></span>
          </summary>
          <div class="tamarinse-faq__answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
</section>

{% stylesheet %}
  .tamarinse-faq {
    display: block;
    background: var(--t-tint);
    color: var(--t-text-hi);
    padding: var(--t-space-section) var(--t-space-md);
  }

  .tamarinse-faq__inner {
    max-width: var(--t-copy-max);
    margin-inline: auto;
  }

  .tamarinse-faq__header {
    margin-block-end: var(--t-space-xl);
  }

  .tamarinse-faq__eyebrow {
    color: var(--t-text-low);
    margin: 0 0 var(--t-space-sm);
  }

  .tamarinse-faq__title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    margin: 0;
  }

  .tamarinse-faq__item {
    border-block-start: 1px solid var(--t-border);
  }

  .tamarinse-faq__item:last-child {
    border-block-end: 1px solid var(--t-border);
  }

  .tamarinse-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--t-space-sm);
    min-height: var(--t-touch-target);
    padding: var(--t-space-md) 0;
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    cursor: pointer;
    list-style: none;
  }

  .tamarinse-faq__question::-webkit-details-marker {
    display: none;
  }

  .tamarinse-faq__marker {
    flex: none;
    position: relative;
    width: 16px;
    height: 16px;
  }

  .tamarinse-faq__marker::before,
  .tamarinse-faq__marker::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto;
    height: 1.5px;
    background: var(--t-text-mid);
    transition: transform var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-faq__marker::after {
    transform: rotate(90deg);
  }

  .tamarinse-faq__item[open] .tamarinse-faq__marker::after {
    transform: rotate(0deg);
  }

  .tamarinse-faq__answer {
    padding-block-end: var(--t-space-md);
    font-size: var(--t-type-body);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    max-width: 60ch;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse FAQ",
  "tag": "section",
  "class": "tamarinse-faq-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Questions, answered."
    },
    {
      "type": "paragraph",
      "content": "Populate questions/answers from the existing Tamarinse.com FAQ (CONTENT.md: reuse existing content)."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tamarinse FAQ",
      "category": "Tamarinse",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "What is Tamarinse?",
            "answer": "<p>Tamarinse is the first premium supplement built around tamarind seed extract for daily environmental defense. Our formula combines five plant-based ingredients designed to support your body's natural detoxification pathways and digestive elimination. 60 capsules per bottle. 30-day supply.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I take it?",
            "answer": "<p>Take 2 capsules daily with water, preferably with a meal. Consistency is key — Tamarinse is designed for daily long-term use, not a one-time cleanse.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is Tamarinse safe to take every day?",
            "answer": "<p>Yes. Every ingredient is USDA Organic, third-party tested, and manufactured in a cGMP certified, FDA registered facility in the USA. The activated charcoal is micro-dosed at 100mg specifically for safe daily use.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Why tamarind?",
            "answer": "<p>Tamarind seed extract contains natural polysaccharides that are currently being studied by researchers worldwide for their ability to bind to microplastic particles in digestive environments. It is the most promising plant-based compound in the category — and the reason we built the entire brand around it.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Why is the bottle made of glass?",
            "answer": "<p>We believe putting a microplastic defense supplement in a plastic bottle defeats the purpose. Our glass bottle is better for the product, better for the planet, and aligned with everything Tamarinse stands for.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Orders ship within 1-2 business days and typically arrive within 5-7 business days depending on your location.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
