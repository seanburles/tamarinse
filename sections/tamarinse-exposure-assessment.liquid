{% comment %}
  Exposure Assessment — stepped flow (client redesign 2026-07-16).
  One question per screen, slim progress bar ("3 of 5"), icon-led answer
  cards, and a single full-width Continue CTA. Each block is one screen with
  up to six answer options (label + icon + weight) so the client can reword,
  re-icon, and re-weight without a deploy. Scoring stays a pure weighted sum
  in tamarinse-exposure-quiz.js; tier thresholds are section settings.
  Client-stated goal: a typical respondent lands on "High".
{% endcomment %}

{%- comment -%}
  Client 2026-07-21: the result CTA must land on the PRODUCT page, not the
  collection listing before it — one less click and one less decision at the
  highest-intent moment in the funnel. Resolution order: explicit link →
  picked product → the shop's first product → the collection as a last resort.
{%- endcomment -%}
{%- liquid
  assign result_link = section.settings.result_cta_link
  if result_link == blank and section.settings.result_product != blank
    assign result_link = section.settings.result_product.url
  endif
  if result_link == blank
    assign first_product = collections.all.products.first
    if first_product != blank
      assign result_link = first_product.url
    endif
  endif
  if result_link == blank
    assign result_link = routes.all_products_collection_url
  endif
-%}

{%- capture tiers_json -%}
  [
    {"tier": {{ section.settings.tier_low | json }}, "threshold": 0, "text": {{ section.settings.result_text_low | json }}},
    {"tier": {{ section.settings.tier_moderate | json }}, "threshold": {{ section.settings.threshold_moderate | divided_by: 100.0 }}, "text": {{ section.settings.result_text_moderate | json }}},
    {"tier": {{ section.settings.tier_high | json }}, "threshold": {{ section.settings.threshold_high | divided_by: 100.0 }}, "text": {{ section.settings.result_text_high | json }}},
    {"tier": {{ section.settings.tier_very_high | json }}, "threshold": {{ section.settings.threshold_very_high | divided_by: 100.0 }}, "text": {{ section.settings.result_text_very_high | json }}}
  ]
{%- endcapture -%}

<tamarinse-exposure-quiz
  class="tamarinse-quiz"
  id="TamarinseQuiz-{{ section.id }}"
  data-tiers="{{ tiers_json | strip | escape }}"
  data-continue-label="{{ section.settings.continue_label | escape }}"
  data-submit-label="{{ section.settings.submit_label | escape }}"
  {%- comment -%}
    Client 2026-07-21: optionally deliver the result ON the product page
    instead of in place. The tier travels as an INDEX (?exposure=3), not a
    label, so renaming a tier in the editor can't break the hand-off.
  {%- endcomment -%}
  data-result-mode="{{ section.settings.result_mode }}"
  data-result-url="{{ result_link }}"
>
  <div class="tamarinse-quiz__inner">
    <header class="tamarinse-quiz__header">
      <p class="t-eyebrow t-eyebrow--ruled-both tamarinse-quiz__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tamarinse-quiz__title">{{ section.settings.title }}</h2>
      <p class="tamarinse-quiz__intro">{{ section.settings.intro }}</p>
    </header>

    <div class="tamarinse-quiz__panel" data-quiz-panel>
      <div class="tamarinse-quiz__progress">
        <span class="tamarinse-quiz__progress-label" data-quiz-progress-label aria-live="polite">
          1 of {{ section.blocks.size }}
        </span>
        <span
          class="tamarinse-quiz__progress-track"
          role="progressbar"
          aria-valuemin="1"
          aria-valuemax="{{ section.blocks.size }}"
          aria-valuenow="1"
          data-quiz-progress-bar
        >
          <span class="tamarinse-quiz__progress-fill" data-quiz-progress-fill></span>
        </span>
      </div>

      <div data-quiz-form>
        {%- for block in section.blocks -%}
          <fieldset
            class="tamarinse-quiz__step"
            data-quiz-step
            {% unless forloop.first %}
              hidden
            {% endunless %}
            {{ block.shopify_attributes }}
          >
            <legend class="tamarinse-quiz__question" tabindex="-1">{{ block.settings.question }}</legend>
            {%- if block.settings.hint != blank -%}
              <p class="tamarinse-quiz__hint">{{ block.settings.hint }}</p>
            {%- endif -%}
            <div class="tamarinse-quiz__options">
              {%- for i in (1..6) -%}
                {%- assign label_key = 'option' | append: i | append: '_label' -%}
                {%- assign icon_key = 'option' | append: i | append: '_icon' -%}
                {%- assign weight_key = 'option' | append: i | append: '_weight' -%}
                {%- if block.settings[label_key] != blank -%}
                  <label class="tamarinse-quiz__option">
                    <input
                      type="checkbox"
                      class="tamarinse-quiz__checkbox"
                      data-weight="{{ block.settings[weight_key] | default: 1 }}"
                    >
                    <span class="tamarinse-quiz__option-icon">
                      {%- render 'tamarinse-quiz-icon', icon: block.settings[icon_key] -%}
                    </span>
                    <span class="tamarinse-quiz__option-label">{{ block.settings[label_key] }}</span>
                  </label>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}

        <div class="tamarinse-quiz__nav">
          <button type="button" class="t-btn t-btn--accent t-btn--block" data-quiz-next>
            {{- section.settings.continue_label -}}
          </button>
          <button type="button" class="tamarinse-quiz__back" data-quiz-back hidden>
            {{- section.settings.back_label -}}
          </button>
        </div>
      </div>
    </div>

    <div class="tamarinse-quiz__result" data-quiz-result tabindex="-1">
      <p class="tamarinse-quiz__result-line">
        {{ section.settings.result_prefix }}
        <strong data-quiz-tier></strong>
      </p>
      {%- comment -%} Always rendered: the JS swaps in the matched tier's copy {%- endcomment -%}
      <p class="tamarinse-quiz__result-text" data-quiz-result-text>{{ section.settings.result_text }}</p>


<div class="tamarinse-quiz__result-actions">
  {%- if section.settings.result_cta_label != blank -%}
    <a class="t-btn t-btn--accent" href="{{ result_link }}">
      {{- section.settings.result_cta_label -}}
    </a>
  {%- endif -%}
  <button type="button" class="tamarinse-quiz__reset" data-quiz-reset>
    {{- section.settings.retake_label -}}
  </button>
</div>
</div>
</div>
</tamarinse-exposure-quiz>

<script src="{{ 'tamarinse-exposure-quiz.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .tamarinse-quiz {
    display: block;
    background: var(--t-tint);
    color: var(--t-text-hi);
    padding: var(--t-space-section) var(--t-space-md);
  }

  .tamarinse-quiz__inner {
    max-width: 44rem;
    margin-inline: auto;
  }

  /* Mobile/tablet: stacked, centered header above the panel.
     Desktop (≥990px) switches to the split rail layout below. */
  .tamarinse-quiz__header {
    text-align: center;
    margin-block-end: var(--t-space-lg);
  }

  .tamarinse-quiz__eyebrow {
    color: var(--t-text-low);
    margin: 0 0 var(--t-space-sm);
  }

  .tamarinse-quiz__title {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h2);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-heading);
    margin: 0 0 var(--t-space-sm);
    text-wrap: balance;
  }

  .tamarinse-quiz__intro {
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    max-width: var(--t-copy-max);
    margin-inline: auto;
    margin-block: 0;
  }

  /* ---- Card panel: one decision per screen ---- */
  .tamarinse-quiz__panel {
    background: var(--t-card);
    border: 1px solid var(--t-border);
    border-radius: 16px;
    padding: var(--t-space-md);
    box-shadow: 0 14px 40px rgb(26 22 14 / 5%);
  }

  .tamarinse-quiz[data-state='result'] .tamarinse-quiz__panel {
    display: none;
  }

  /* ---- Progress ---- */
  .tamarinse-quiz__progress {
    display: flex;
    align-items: center;
    gap: var(--t-space-sm);
    margin-block-end: var(--t-space-lg);
  }

  .tamarinse-quiz__progress-label {
    flex: none;
    font-size: var(--t-type-small);
    font-variant-numeric: tabular-nums;
    color: var(--t-text-low);
  }

  .tamarinse-quiz__progress-track {
    flex: 1;
    height: 4px;
    border-radius: var(--t-radius-pill);
    background: var(--t-surface);
    overflow: hidden;
  }

  .tamarinse-quiz__progress-fill {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: inherit;
    background: var(--t-accent);
    transition: width var(--t-dur-med) var(--t-ease-out);
  }

  /* ---- Steps ---- */
  .tamarinse-quiz__step {
    border: 0;
    padding: 0;
    margin: 0;
    min-height: 19rem;
  }

  .tamarinse-quiz__step[data-entering='forward'] {
    animation: tamarinse-quiz-step-forward 360ms var(--t-ease-out) both;
  }

  .tamarinse-quiz__step[data-entering='back'] {
    animation: tamarinse-quiz-step-back 360ms var(--t-ease-out) both;
  }

  @keyframes tamarinse-quiz-step-forward {
    from {
      opacity: 0;
      transform: translateX(28px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes tamarinse-quiz-step-back {
    from {
      opacity: 0;
      transform: translateX(-28px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  .tamarinse-quiz__question {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h3);
    line-height: var(--t-leading-heading);
    font-weight: var(--t-weight-subheading);
    padding: 0;
    margin: 0 0 var(--t-space-2xs);
    outline: none;
    text-wrap: balance;
  }

  .tamarinse-quiz__hint {
    font-size: var(--t-type-small);
    color: var(--t-text-low);
    margin: 0 0 var(--t-space-md);
  }

  /* ---- Icon answer cards ---- */
  .tamarinse-quiz__options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--t-space-xs);
    margin-block-start: var(--t-space-md);
  }

  .tamarinse-quiz__option {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--t-space-xs);
    min-height: var(--t-touch-target);
    padding: var(--t-space-sm);
    background: var(--t-card);
    border: 1px solid var(--t-border);
    border-radius: 12px;
    cursor: pointer;
    overflow: hidden;
    -webkit-tap-highlight-color: transparent;
    transition: border-color var(--t-dur-fast) var(--t-ease-out), background-color var(--t-dur-fast) var(--t-ease-out),
      box-shadow var(--t-dur-fast) var(--t-ease-out);
  }

  .tamarinse-quiz__option:hover {
    border-color: var(--t-text-low);
  }

  .tamarinse-quiz__checkbox {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* Icon chip: duotone glyph in the accent green on a soft tinted square —
     the icons carry the accent so the cards read as tappable choices. */
  .tamarinse-quiz__option-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--t-accent-tint);
    color: var(--t-accent);
    transition: background-color var(--t-dur-fast) var(--t-ease-out), color var(--t-dur-fast) var(--t-ease-out);
  }

  /* Duotone icons: a soft "contents" layer under the outline (water in the
     bottle, coffee in the cup, food in the tub). A filled mass is read far
     faster than an outline at 26px, and it matches the duotone language the
     capsule and quality-standards icons already use. Inherits currentColor,
     so it works on the tinted chip AND on the solid-accent selected state. */
  .tamarinse-quiz-icon .qi-fill {
    fill: currentColor;
    fill-opacity: 0.16;
    stroke: none;
  }

  .tamarinse-quiz__option-label {
    font-size: var(--t-type-body);
    line-height: 1.35;
    font-weight: 500;
    text-align: center;
    margin-top: 10px;
  }

  /* Selected: bold accent border + tinted fill — the accent's one job here */
  .tamarinse-quiz__option:has(.tamarinse-quiz__checkbox:checked) {
    border-color: var(--t-accent);
    box-shadow: inset 0 0 0 1px var(--t-accent);
    background: var(--t-accent-tint);
  }

  /* Selected card: the chip flips solid — instant read at a glance */
  .tamarinse-quiz__option:has(.tamarinse-quiz__checkbox:checked) .tamarinse-quiz__option-icon {
    background: var(--t-accent);
    color: #fff;
  }

  .tamarinse-quiz__option:has(.tamarinse-quiz__checkbox:focus-visible) {
    outline: 2px solid var(--t-accent);
    outline-offset: 3px;
  }

  /* ---- Navigation ---- */
  .tamarinse-quiz__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--t-space-2xs);
    margin-block-start: var(--t-space-lg);
  }

  .tamarinse-quiz__back {
    background: none;
    border: none;
    color: var(--t-text-mid);
    font-size: var(--t-type-small);
    text-decoration: underline;
    cursor: pointer;
    min-height: var(--t-touch-target);
    padding: 0 var(--t-space-sm);
  }

  /* ---- Result ---- */
  .tamarinse-quiz__result {
    display: none;
    padding: var(--t-space-lg);
    background: var(--t-card);
    color: var(--t-text-hi);
    border: 1px solid var(--t-border);
    border-radius: 16px;
    box-shadow: 0 14px 40px rgb(26 22 14 / 5%);
    outline: none;
    animation: tamarinse-quiz-step-forward 360ms var(--t-ease-out) both;
  }

  .tamarinse-quiz[data-state='result'] .tamarinse-quiz__result {
    display: block;
  }

  .tamarinse-quiz__result-line {
    font-family: var(--t-font-heading);
    font-size: var(--t-type-h3);
    line-height: var(--t-leading-heading);
    margin: 0 0 var(--t-space-sm);
  }

  .tamarinse-quiz__result-line strong {
    color: var(--t-accent);
    font-weight: 500;
  }

  .tamarinse-quiz__result-text {
    font-size: var(--t-type-body-lg);
    line-height: var(--t-leading-body);
    color: var(--t-text-mid);
    max-width: var(--t-copy-max);
    margin: 0 0 var(--t-space-md);
  }

  .tamarinse-quiz__result-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--t-space-md);
  }

  .tamarinse-quiz__reset {
    background: none;
    border: none;
    color: var(--t-text-mid);
    font-size: var(--t-type-small);
    text-decoration: underline;
    cursor: pointer;
    min-height: var(--t-touch-target);
    padding: 0 var(--t-space-xs);
  }

  @media (prefers-reduced-motion: reduce) {
    .tamarinse-quiz__step[data-entering='forward'],
    .tamarinse-quiz__step[data-entering='back'],
    .tamarinse-quiz__result {
      animation: none;
    }
  }

  @media screen and (min-width: 750px) {
    .tamarinse-quiz__panel {
      padding: var(--t-space-lg);
    }

    .tamarinse-quiz__options {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--t-space-sm);
    }

    .tamarinse-quiz__option {
      padding: var(--t-space-sm) var(--t-space-sm);
    }
  }

  /* ---- Desktop: split layout matching the ingredient-science section —
     sticky title/intro rail on the left, quiz panel on the right ---- */
  @media screen and (min-width: 990px) {
    .tamarinse-quiz__inner {
      max-width: var(--t-content-max);
      display: grid;
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--t-space-2xl);
      align-items: start;
    }

    .tamarinse-quiz__header {
      position: sticky;
      top: calc(var(--header-height, 64px) + var(--t-space-lg));
      text-align: left;
      margin-block-end: 0;
    }

    .tamarinse-quiz__intro {
      margin-inline: 0;
    }

    /* Panel and result share the right-hand cell; the quiz's data-state
       toggles which one is displayed. */
    .tamarinse-quiz__panel,
    .tamarinse-quiz__result {
      grid-column: 2;
      grid-row: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tamarinse Exposure Quiz",
  "tag": "section",
  "class": "tamarinse-quiz-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Exposure Assessment"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How exposed are you to microplastics?"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro",
      "default": "A 60-second check on your daily routines."
    },
    {
      "type": "text",
      "id": "continue_label",
      "label": "Continue button label",
      "default": "Continue"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Final step button label",
      "default": "See my result"
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Back link label",
      "default": "Back"
    },
    {
      "type": "header",
      "content": "Result"
    },
    {
      "type": "text",
      "id": "result_prefix",
      "label": "Result line (tier is appended)",
      "default": "Your estimated exposure is"
    },
    {
      "type": "textarea",
      "id": "result_text",
      "label": "Result supporting text (fallback)",
      "default": "Exposure adds up quietly, through everyday routines. Tamarinse™ was designed for exactly this.",
      "info": "Shown if the matching tier's text below is left blank."
    },
    {
      "type": "textarea",
      "id": "result_text_low",
      "label": "Supporting text — tier 1",
      "default": "Even careful routines can't avoid the microplastics already in food, water, and air. Tamarinse™ was designed as simple daily support for exactly that baseline — a good fit for keeping it that way."
    },
    {
      "type": "textarea",
      "id": "result_text_moderate",
      "label": "Supporting text — tier 2",
      "default": "Several of your everyday habits are recognized microplastic sources, and that kind of exposure adds up quietly. This cumulative pattern is what Tamarinse™ was designed for — you're a good candidate for daily support."
    },
    {
      "type": "textarea",
      "id": "result_text_high",
      "label": "Supporting text — tier 3",
      "default": "Your routine includes many of the most common everyday exposure sources — the exact pattern Tamarinse™ was formulated around. Starting daily support now is a strong fit for habits like yours."
    },
    {
      "type": "textarea",
      "id": "result_text_very_high",
      "label": "Supporting text — tier 4",
      "default": "Your answers cover most of the major everyday exposure sources. Routines like this are exactly what daily binding support was made for — Tamarinse™ is a strong candidate for your daily lineup."
    },
    {
      "type": "text",
      "id": "result_cta_label",
      "label": "Result button label",
      "default": "Meet Tamarinse™"
    },
    {
      "type": "select",
      "id": "result_mode",
      "label": "Where the result appears",
      "options": [
        { "value": "inline", "label": "On this page" },
        { "value": "product", "label": "On the product page" }
      ],
      "default": "inline",
      "info": "\"On the product page\" sends people straight there after the last question and shows their tier at the top. Requires the Exposure Result section on the product template."
    },
    {
      "type": "product",
      "id": "result_product",
      "label": "Result button product",
      "info": "Sends people straight to this product page after the quiz. Defaults to the shop's first product if left empty."
    },
    {
      "type": "url",
      "id": "result_cta_link",
      "label": "Result button link (overrides the product above)"
    },
    {
      "type": "text",
      "id": "retake_label",
      "label": "Retake link label",
      "default": "Retake the assessment"
    },
    {
      "type": "header",
      "content": "Tiers"
    },
    {
      "type": "text",
      "id": "tier_low",
      "label": "Tier 1 label",
      "default": "Low"
    },
    {
      "type": "text",
      "id": "tier_moderate",
      "label": "Tier 2 label",
      "default": "Moderate"
    },
    {
      "type": "range",
      "id": "threshold_moderate",
      "label": "Tier 2 starts at (% of max score)",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "text",
      "id": "tier_high",
      "label": "Tier 3 label",
      "default": "High"
    },
    {
      "type": "range",
      "id": "threshold_high",
      "label": "Tier 3 starts at (% of max score)",
      "min": 20,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "text",
      "id": "tier_very_high",
      "label": "Tier 4 label",
      "default": "Very High"
    },
    {
      "type": "range",
      "id": "threshold_very_high",
      "label": "Tier 4 starts at (% of max score)",
      "min": 50,
      "max": 95,
      "step": 5,
      "unit": "%",
      "default": 70
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question screen",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "text",
          "id": "hint",
          "label": "Hint",
          "default": "Select all that apply"
        },
        {
          "type": "header",
          "content": "Option 1"
        },
        { "type": "text", "id": "option1_label", "label": "Label" },
        {
          "type": "select",
          "id": "option1_icon",
          "label": "Icon",
          "options": [
            { "value": "bottle", "label": "Plastic water bottle" },
            { "value": "soda", "label": "Soft-drink bottle" },
            { "value": "cup", "label": "To-go coffee cup" },
