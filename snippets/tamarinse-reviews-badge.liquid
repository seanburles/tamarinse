{% doc %}
  Reviews badge — rating + count + source label, fully data-driven
  (BUILD_GUIDE section 4). Renders nothing when count is zero/blank so an
  empty store never shows a fabricated-looking badge.

  @param {number} rating
  @param {number} count
  @param {string} source
{% enddoc %}

{%- if count != blank and count > 0 -%}
  {%- liquid
    # Fifth star fills fractionally so a 4.8 doesn't read as a fabricated 5.0.
    assign whole_stars = rating | floor
    assign fraction_pct = rating | minus: whole_stars | times: 100 | round
    assign partial_index = whole_stars | plus: 1

    # Thousands separator; round counts read as "at least" with a plus.
    if count >= 1000
      assign thousands = count | divided_by: 1000
      assign remainder = count | modulo: 1000
      assign rem_str = remainder | prepend: '000' | slice: -3, 3
      assign count_label = thousands | append: ',' | append: rem_str
      if remainder == 0
        assign count_label = count_label | append: '+'
      endif
    else
      assign count_label = count
    endif
  -%}
  <p class="tamarinse-reviews-badge">
    <span class="tamarinse-reviews-badge__stars" aria-hidden="true">
      {%- for i in (1..5) -%}
        {%- if i <= whole_stars -%}
          <span class="tamarinse-reviews-badge__star">&#9733;</span>
        {%- elsif fraction_pct > 0 and i == partial_index -%}
          <span class="tamarinse-reviews-badge__star tamarinse-reviews-badge__star--partial"
            ><span class="tamarinse-reviews-badge__star-fill" style="width: {{ fraction_pct }}%;">&#9733;</span
            ><span class="tamarinse-reviews-badge__star-base">&#9733;</span
          ></span>
        {%- else -%}
          <span class="tamarinse-reviews-badge__star tamarinse-reviews-badge__star--empty">&#9733;</span>
        {%- endif -%}
      {%- endfor -%}
    </span>
    <span class="tamarinse-reviews-badge__text">
      {{ rating }} out of 5 &middot; {{ count_label }} {{ source }}
    </span>
  </p>
{%- endif -%}

{% stylesheet %}
  .tamarinse-reviews-badge {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 0.5rem;
    row-gap: 0.15rem;
    margin: 0;
    font-size: var(--t-type-small);
    line-height: 1.3;
  }

  /* Flex row so the 5th star never orphans onto its own line */
  .tamarinse-reviews-badge__stars {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.12em;
    color: var(--t-accent-2);
    white-space: nowrap;
  }

  .tamarinse-reviews-badge__star {
    flex: none;
    line-height: 1;
  }

  .tamarinse-reviews-badge__star--empty {
    opacity: 0.25;
  }

  .tamarinse-reviews-badge__star--partial {
    position: relative;
    display: inline-block;
  }

  .tamarinse-reviews-badge__star-base {
    opacity: 0.25;
  }

  .tamarinse-reviews-badge__star-fill {
    position: absolute;
    inset: 0 auto 0 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .tamarinse-reviews-badge__text {
    color: var(--t-text-low);
    min-width: 0;
  }
{% endstylesheet %}
