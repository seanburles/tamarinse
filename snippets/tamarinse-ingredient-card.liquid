{% doc %}
  Renders one ingredient card for the Ingredient Science section and the
  product page. Accepts either a metaobject entry or plain strings from a
  section block, so both data paths render identically.

  @param {string} name
  @param {string} what_it_is
  @param {string} why_we_chose_it
  @param {string} research_orgs - newline- or comma-separated list (blocks) —
    metaobject callers pass the joined list value the same way
  @param {string} orgs_label
  @param {object} [image] - optional merchant-picked ingredient photo

  When no image is picked, known ingredients fall back to the bundled
  photography pulled from tamarinse.com (client-approved source).
{% enddoc %}

{%- liquid
  assign photo_asset = ''
  if image == blank
    if name contains 'Tamarind'
      assign photo_asset = 'tamarinse-ingredient-tamarind.jpg'
    elsif name contains 'Okra'
      assign photo_asset = 'tamarinse-ingredient-okra.jpg'
    elsif name contains 'Fenugreek'
      assign photo_asset = 'tamarinse-ingredient-fenugreek.jpg'
    elsif name contains 'Milk Thistle'
      assign photo_asset = 'tamarinse-ingredient-milk-thistle.jpg'
    endif
  endif
-%}

<article class="tamarinse-ingredient-card">
  {%- if image != blank -%}
    <div class="tamarinse-ingredient-card__media">
      {{
        image
        | image_url: width: 800
        | image_tag: widths: '400, 800', class: 'tamarinse-ingredient-card__photo', loading: 'lazy', alt: image.alt
      }}
    </div>
  {%- elsif photo_asset != blank -%}
    <div class="tamarinse-ingredient-card__media">
      <img
        src="{{ photo_asset | asset_url }}"
        class="tamarinse-ingredient-card__photo"
        alt="{{ name | escape }}"
        width="800"
        height="540"
        loading="lazy"
      >
    </div>
  {%- endif -%}
  <h3 class="tamarinse-ingredient-card__name">{{ name }}</h3>
  <div class="tamarinse-ingredient-card__body">
    <p class="tamarinse-ingredient-card__what">{{ what_it_is }}</p>
    <p class="tamarinse-ingredient-card__why">{{ why_we_chose_it }}</p>
  </div>
  {%- if research_orgs != blank -%}
    {%- liquid
      assign orgs = research_orgs | newline_to_br | split: '<br />'
      if orgs.size == 1
        assign orgs = research_orgs | split: ';'
      endif
    -%}
    <div class="tamarinse-ingredient-card__orgs">
      <p class="t-eyebrow tamarinse-ingredient-card__orgs-label">{{ orgs_label | default: 'Research Organizations' }}</p>
      <ul class="tamarinse-ingredient-card__orgs-list">
        {%- for org in orgs -%}
          {%- assign org_stripped = org | strip -%}
          {%- if org_stripped != blank -%}
            <li>{{ org_stripped }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}
</article>
