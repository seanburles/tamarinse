{% doc %}
  Brand flourish — a small tamarind-leaf sprig between hairline rules,
  echoing the leaf accents and "— tamarinse.com —" rule treatment on the
  brand's print materials. Decorative only.

  @param {string} align - 'center' (default) or 'start'
{% enddoc %}

<div class="tamarinse-flourish{% if align == 'start' %} tamarinse-flourish--start{% endif %}" aria-hidden="true">
  <span class="tamarinse-flourish__rule"></span>
  <svg class="tamarinse-flourish__sprig" viewBox="0 0 40 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 22C20 15 20 8 20 3"/>
    <path d="M20 17C15.5 16 11.5 13 10.5 8.5C15 9.5 18.9 12.5 20 17Z"/>
    <path d="M20 17C24.5 16 28.5 13 29.5 8.5C25 9.5 21.1 12.5 20 17Z"/>
    <path d="M20 10C16.8 9.2 14.3 6.8 13.8 3.8C17 4.7 19.3 7 20 10Z"/>
    <path d="M20 10C23.2 9.2 25.7 6.8 26.2 3.8C23 4.7 20.7 7 20 10Z"/>
  </svg>
  <span class="tamarinse-flourish__rule"></span>
</div>

{% stylesheet %}
  .tamarinse-flourish {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--t-space-sm);
    color: var(--t-accent-2);
  }

  .tamarinse-flourish--start {
    justify-content: flex-start;
  }

  .tamarinse-flourish__rule {
    width: 2.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.45;
  }

  .tamarinse-flourish__sprig {
    width: 22px;
    height: 14px;
    flex-shrink: 0;
    color: var(--t-accent);
  }
{% endstylesheet %}
