{% comment %}
  Inline line-icon set for quiz answer cards.
  Usage: {% render 'tamarinse-quiz-icon', icon: 'bottle' %}
  Consistent 24px viewBox, 1.75 stroke, currentColor — matches the
  minimalist line-icon rule in MASTER_PROMPT.md.
{% endcomment %}

<svg
  class="tamarinse-quiz-icon"
  viewBox="0 0 24 24"
  width="28"
  height="28"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case icon -%}
    {%- when 'bottle' -%}
      <path d="M10 2.5h4v3l1.5 2.5V20a1.5 1.5 0 0 1-1.5 1.5h-4A1.5 1.5 0 0 1 8.5 20V8L10 5.5v-3z"/>
      <path d="M8.5 12.5h7M8.5 16.5h7"/>
    {%- when 'cup' -%}
      <path d="M6.5 8.5 8 20.2a1.5 1.5 0 0 0 1.5 1.3h5a1.5 1.5 0 0 0 1.5-1.3L17.5 8.5"/>
      <path d="M5.5 8.5h13M7 8.5l.7-3.5h8.6l.7 3.5M12 5V2.5"/>
    {%- when 'shaker' -%}
      <path d="M8.5 7.5h7l1 12.5a1.5 1.5 0 0 1-1.5 1.5h-6a1.5 1.5 0 0 1-1.5-1.5l1-12.5z"/>
      <path d="M9 4.5h6v3H9zM10.5 2.5h3M8 13h8"/>
    {%- when 'teabag' -%}
      <path d="M12 3v3.5M12 6.5l-3.5 3v9a1.5 1.5 0 0 0 1.5 1.5h4a1.5 1.5 0 0 0 1.5-1.5v-9l-3.5-3z"/>
      <path d="M12 3l4 2.5M16 5.5l1.5-1M9.75 13.5h4.5"/>
    {%- when 'jar' -%}
      <path d="M8 2.5h8M8.75 2.5V5L7 8v11a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V8l-1.75-3V2.5"/>
      <path d="M7 12h10"/>
    {%- when 'container' -%}
      <path d="M4.5 9.5h15v8a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2v-8z"/>
      <path d="M3.5 9.5 5 6h14l1.5 3.5M12 6v3.5"/>
    {%- when 'microwave' -%}
      <rect x="3" y="6" width="18" height="13" rx="1.5"/>
      <path d="M16.5 6v13"/>
      <rect x="5.75" y="9" width="8" height="7" rx="1"/>
      <path d="M19 9.5v.01M19 12.5v.01"/>
    {%- when 'bag' -%}
      <path d="M6.5 8h11l1.5 11a2 2 0 0 1-2 2.3H7a2 2 0 0 1-2-2.3L6.5 8z"/>
      <path d="M9 10.5V7a3 3 0 0 1 6 0v3.5"/>
    {%- when 'pan' -%}
      <circle cx="10" cy="14" r="6"/>
      <path d="M15.5 11.5l6-2.5M10 11.5a2.5 2.5 0 0 1 2.5 2.5"/>
    {%- when 'board' -%}
      <path d="M7 3.5h10a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-13a2 2 0 0 1 2-2z"/>
      <path d="M12 6.75v.01M8.5 11l7 6M15.5 11l-7 6"/>
    {%- when 'takeout' -%}
      <path d="M6 8.5h12L16.5 21h-9L6 8.5z"/>
      <path d="M6 8.5 8 4h8l2 4.5M9.5 12l2.5 2.5L14.5 12"/>
    {%- when 'package' -%}
      <rect x="5" y="5.5" width="14" height="15" rx="1.5"/>
      <path d="M5 10h14M9 3v4.5M15 3v4.5M9.5 14.5h5"/>
    {%- when 'fish' -%}
      <path d="M4 12s3.5-5.5 9-5.5c3.5 0 7 3 7 5.5s-3.5 5.5-7 5.5c-5.5 0-9-5.5-9-5.5z"/>
      <path d="M4 12 2.5 8.5M4 12l-1.5 3.5M16 10.5v.01"/>
    {%- when 'shirt' -%}
      <path d="M8.5 3.5 3.5 7 6 10.5l2-1.25V20.5h8V9.25l2 1.25L20.5 7l-5-3.5a3.5 3.5 0 0 1-7 0z"/>
    {%- when 'receipt' -%}
      <path d="M6.5 2.5h11v19l-2-1.5-1.85 1.5L12 20l-1.65 1.5L8.5 20l-2 1.5v-19z"/>
      <path d="M9.5 7h5M9.5 10.5h5M9.5 14h3"/>
    {%- when 'droplet' -%}
      <path d="M12 3s6 7 6 11.25a6 6 0 0 1-12 0C6 10 12 3 12 3z"/>
    {%- when 'none' -%}
      <circle cx="12" cy="12" r="8.5"/>
      <path d="M7.5 12h9"/>
    {%- else -%}
      <circle cx="12" cy="12" r="8.5"/>
      <path d="M12 8v4.5M12 15.75v.01"/>
  {%- endcase -%}
</svg>
