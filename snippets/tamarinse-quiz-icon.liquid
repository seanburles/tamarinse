{% comment %}
  Inline icon set for quiz answer cards — Lucide Icons (ISC license,
  lucide.dev). Stroke-based, 24×24 viewBox, consistent 2px weight for
  crisp readability at the 26px chip size. Icon keys are unchanged from
  the original set so existing section settings keep working.

  Usage: {% render 'tamarinse-quiz-icon', icon: 'bottle' %}
{% endcomment %}

<svg
  class="tamarinse-quiz-icon"
  viewBox="0 0 24 24"
  width="26"
  height="26"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case icon -%}
    {%- when 'bottle' -%}
      {%- comment -%} Water bottle (lucide:flask-conical) {%- endcomment -%}
      <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
      <path d="M8.5 2h7"/><path d="M7 16h10"/>
    {%- when 'cup' -%}
      {%- comment -%} Coffee cup (lucide:coffee) {%- endcomment -%}
      <path d="M10 2v2"/><path d="M14 2v2"/>
      <path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a2 2 0 1 1 0 4h-1"/>
    {%- when 'shaker' -%}
      {%- comment -%} Sports bottle (lucide:glass-water) {%- endcomment -%}
      <path d="M15.2 22H8.8a2 2 0 0 1-2-1.79L5 3h14l-1.81 17.21A2 2 0 0 1 15.2 22Z"/>
      <path d="M6 12h12"/>
    {%- when 'teabag' -%}
      {%- comment -%} Tea / leaf drink (lucide:leaf) {%- endcomment -%}
      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
      <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
    {%- when 'jar' -%}
      {%- comment -%} Glass jar (lucide:archive) {%- endcomment -%}
      <rect width="20" height="5" x="2" y="3" rx="1"/>
      <path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/>
    {%- when 'container' -%}
      {%- comment -%} Plastic container (lucide:box) {%- endcomment -%}
      <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
      <path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>
    {%- when 'microwave' -%}
      {%- comment -%} Microwave (lucide:microwave) {%- endcomment -%}
      <rect width="20" height="15" x="2" y="4" rx="2"/>
      <rect width="8" height="7" x="6" y="8" rx="1"/>
      <path d="M18 8v7"/><path d="M6 19v2"/><path d="M18 19v2"/>
    {%- when 'bag' -%}
      {%- comment -%} Plastic bag (lucide:shopping-bag) {%- endcomment -%}
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
      <path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
    {%- when 'pan' -%}
      {%- comment -%} Non-stick pan (lucide:cooking-pot) {%- endcomment -%}
      <path d="M2 12h20"/><path d="M20 12v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8"/>
      <path d="m4 8 16-4"/><path d="m8.86 6.78-.45-1.81a2 2 0 0 1 1.45-2.43l1.94-.48a2 2 0 0 1 2.43 1.46l.45 1.8"/>
    {%- when 'board' -%}
      {%- comment -%} Cutting board (lucide:rectangle-horizontal) {%- endcomment -%}
      <rect width="20" height="12" x="2" y="6" rx="2"/>
    {%- when 'takeout' -%}
      {%- comment -%} Takeout food (lucide:utensils) {%- endcomment -%}
      <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/>
      <path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>
    {%- when 'package' -%}
      {%- comment -%} Packaged food (lucide:package) {%- endcomment -%}
      <path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
      <path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>
    {%- when 'fish' -%}
      {%- comment -%} Seafood (lucide:fish) {%- endcomment -%}
      <path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.47-3.44 6-7 6-3.56 0-7.56-2.53-8.5-6Z"/>
      <path d="M18 12v.5"/><path d="M16 17.93a9.77 9.77 0 0 1 0-11.86"/>
      <path d="M7 10.67C7 8 5.58 5.97 2.73 5.5c-1 1.5-1 5 .23 6.5-1.24 1.5-1.24 5 .23 6.5C5.58 18.03 7 16 7 13.33"/>
    {%- when 'shirt' -%}
      {%- comment -%} Clothing (lucide:shirt) {%- endcomment -%}
      <path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 1 .84H6v10h12V10h2.14a1 1 0 0 0 1-.84l.58-3.47a2 2 0 0 0-1.34-2.23Z"/>
    {%- when 'receipt' -%}
      {%- comment -%} Paper receipt (lucide:receipt) {%- endcomment -%}
      <path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/>
      <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/>
      <path d="M12 17.5v-11"/>
    {%- when 'droplet' -%}
      {%- comment -%} Water / glass (lucide:droplet) {%- endcomment -%}
      <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>
    {%- when 'none' -%}
      {%- comment -%} None / circle-off (lucide:circle-slash) {%- endcomment -%}
      <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
    {%- else -%}
      {%- comment -%} Fallback question mark (lucide:circle-help) {%- endcomment -%}
      <circle cx="12" cy="12" r="10"/>
      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
      <path d="M12 17h.01"/>
  {%- endcase -%}
</svg>
