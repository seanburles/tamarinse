{% doc %}
  PDP trust signals — compact icon + text rows under the buy buttons.
  Mirrors the announcement-bar promises (guarantee, shipping threshold,
  testing) so the buy box answers objections right at the point of decision.
{% enddoc %}

<ul class="tamarinse-pdp-trust" role="list">
  <li class="tamarinse-pdp-trust__item">
    <svg class="tamarinse-pdp-trust__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 2.2 3.8 4.6v4.6c0 4 2.6 6.9 6.2 8.2 3.6-1.3 6.2-4.2 6.2-8.2V4.6L10 2.2Z"/>
      <path d="m7.2 10 2 2 3.6-3.8"/>
    </svg>
    <span>30-day money-back guarantee</span>
  </li>
  <li class="tamarinse-pdp-trust__item">
    <svg class="tamarinse-pdp-trust__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M1.8 5h9.4v9H1.8zM11.2 8h3.6l3.4 3.2V14h-7z"/>
      <circle cx="5.4" cy="15.6" r="1.6"/>
      <circle cx="14.6" cy="15.6" r="1.6"/>
    </svg>
    <span>Free U.S. shipping on orders over $40</span>
  </li>
  <li class="tamarinse-pdp-trust__item">
    <svg class="tamarinse-pdp-trust__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8 2.5h4M8.8 2.5v5L4.6 14.8a1.6 1.6 0 0 0 1.4 2.4h8a1.6 1.6 0 0 0 1.4-2.4L11.2 7.5v-5"/>
      <path d="M6.4 12.4h7.2"/>
    </svg>
    <span>Third-party tested &middot; cGMP certified</span>
  </li>
</ul>

{% stylesheet %}
  .tamarinse-pdp-trust {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tamarinse-pdp-trust__item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: var(--t-type-small, 0.875rem);
    color: var(--t-text-mid, rgb(25 23 18 / 70%));
  }

  .tamarinse-pdp-trust__icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--t-accent, #0d7a3f);
  }
{% endstylesheet %}
