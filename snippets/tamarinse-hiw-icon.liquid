{% comment %}
  Inline icon set for How It Works step cards — Lucide Icons (ISC license,
  lucide.dev). Stroke-based, 24×24 viewBox, consistent 1.5px weight for
  clean readability at the card-media size.

  Usage: {% render 'tamarinse-hiw-icon', icon: 'exposure' %}
{% endcomment %}

<svg
  class="tamarinse-hiw-icon"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {%- case icon -%}
    {%- when 'exposure' -%}
      {%- comment -%}
        Suspended particles drifting toward a silhouette droplet — everyday
        microplastic exposure. (Custom mark; a plain cloud read as "weather".)
      {%- endcomment -%}
      <path d="M12 21a6 6 0 0 0 6-6c0-4-6-11-6-11S6 11 6 15a6 6 0 0 0 6 6Z"/>
      <circle cx="4" cy="5" r="1" fill="currentColor" stroke="none"/>
      <circle cx="9" cy="2.5" r="0.8" fill="currentColor" stroke="none"/>
      <circle cx="15" cy="2" r="1" fill="currentColor" stroke="none"/>
      <circle cx="20" cy="4.5" r="0.8" fill="currentColor" stroke="none"/>
      <circle cx="21" cy="10" r="1" fill="currentColor" stroke="none"/>
      <circle cx="3" cy="11" r="0.8" fill="currentColor" stroke="none"/>
    {%- when 'activates' -%}
      {%- comment -%} Zap — capsule activation (lucide:zap) {%- endcomment -%}
      <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
    {%- when 'binds' -%}
      {%- comment -%} Link — binding compounds (lucide:link) {%- endcomment -%}
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
    {%- when 'supports' -%}
      {%- comment -%} Shield with check — protective support (lucide:shield-check) {%- endcomment -%}
      <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
      <path d="m9 12 2 2 4-4"/>
    {%- when 'eliminates' -%}
      {%- comment -%} Leaf — natural elimination (lucide:leaf) {%- endcomment -%}
      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
      <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
    {%- else -%}
      {%- comment -%} Fallback circle (lucide:circle) {%- endcomment -%}
      <circle cx="12" cy="12" r="10"/>
  {%- endcase -%}
</svg>
