        "badge_source": "customer reviews"
      },
      "blocks": {
        "r1": { "type": "review", "settings": { "quote": "Love that it's actually in a glass bottle. I've been trying to reduce unnecessary plastic exposure where I can, so seeing a supplement focused on modern environmental wellness packaged in glass immediately caught my attention. The ingredient list is transparent and the quality feels premium.", "name": "J.", "role": "Verified buyer", "rating": 5 } },
        "r2": { "type": "review", "settings": { "quote": "Exactly what I've been looking for. I kept hearing people talk about tamarind whenever microplastics came up, but I couldn't find a product built around it. When I found Tamarinse, it immediately made sense. Clean ingredients, glass bottle, and a formula I can actually understand.", "name": "S.", "role": "Verified buyer", "rating": 5 } },
        "r3": { "type": "review", "settings": { "quote": "The first supplement that actually feels different. Most supplements look exactly the same. Tamarinse stood out because it's built around tamarind and has a clear reason for existing. The formula, packaging, and overall brand feel thoughtful and intentional.", "name": "L.", "role": "Verified buyer", "rating": 5 } },
        "r4": { "type": "review", "settings": { "quote": "Fits into my morning without any fuss. Two capsules with breakfast and I'm done — no chalky taste, easy to swallow, and the bottle looks good enough that I don't hide it in a cabinet. Three months in and reordering was an easy decision.", "name": "M.T.", "role": "Verified buyer", "rating": 5 } },
        "r5": { "type": "review", "settings": { "quote": "I was skeptical, so I did my homework first. I actually looked up the research organizations they cite before ordering, and everything checked out. It's rare to find a brand this transparent about what's in the formula and why each ingredient is there. Would love a larger bottle option, but that's my only note.", "name": "D.R.", "role": "Verified buyer", "rating": 4 } },
        "r6": { "type": "review", "settings": { "quote": "Bought it for my husband, now we both take it. He's the health-conscious one, but once I read about how much plastic we're all exposed to through takeout and coffee lids, I started taking it too. It's become part of our routine, like brushing your teeth.", "name": "C.B.", "role": "Verified buyer", "rating": 5 } }
      },
      "block_order": ["r1", "r2", "r3", "r4", "r5", "r6"]
    },
    "faq": {
      "type": "tamarinse-faq",
      "blocks": {
        "f1": { "type": "faq", "settings": { "question": "What is Tamarinse?", "answer": "<p>Tamarinse is the first premium supplement built around tamarind seed extract for daily environmental defense. Our formula combines five plant-based ingredients designed to support your body's natural detoxification pathways and digestive elimination. 60 capsules per bottle. 30-day supply.</p>" } },
        "f2": { "type": "faq", "settings": { "question": "How do I take it?", "answer": "<p>Take 2 capsules daily with water, preferably with a meal. Consistency is key — Tamarinse is designed for daily long-term use, not a one-time cleanse.</p>" } },
        "f3": { "type": "faq", "settings": { "question": "Is Tamarinse safe to take every day?", "answer": "<p>Yes. Every ingredient is USDA Organic, third-party tested, and manufactured in a cGMP certified, FDA registered facility in the USA. The activated charcoal is micro-dosed at 100mg specifically for safe daily use.</p>" } },
        "f4": { "type": "faq", "settings": { "question": "Why tamarind?", "answer": "<p>Tamarind seed extract contains natural polysaccharides that are currently being studied by researchers worldwide for their ability to bind to microplastic particles in digestive environments. It is the most promising plant-based compound in the category — and the reason we built the entire brand around it.</p>" } },
        "f5": { "type": "faq", "settings": { "question": "Why is the bottle made of glass?", "answer": "<p>We believe putting a microplastic defense supplement in a plastic bottle defeats the purpose. Our glass bottle is better for the product, better for the planet, and aligned with everything Tamarinse stands for.</p>" } },
        "f6": { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "<p>Orders ship within 1-2 business days and typically arrive within 5-7 business days depending on your location.</p>" } }
